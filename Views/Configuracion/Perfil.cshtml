@model VitalBand.Models.UsuarioResumen
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env
@{
    ViewData["Title"] = "Mi Cuenta - VitalBand";
    var claimId = User.FindFirst("UsuarioBaseId")?.Value;
    string userAvatarUrl = "/images/avatar-placeholder.png";
    if (!string.IsNullOrEmpty(claimId))
    {
        var uploadsDir = System.IO.Path.Combine(Env.ContentRootPath, "wwwroot", "uploads", "avatars");
        if (System.IO.Directory.Exists(uploadsDir))
        {
            var files = System.IO.Directory.GetFiles(uploadsDir, claimId + ".*");
            if (files.Length > 0)
            {
                userAvatarUrl = "/uploads/avatars/" + System.IO.Path.GetFileName(files[0]);
            }
        }
    }
}

@section Styles {
    <style>
        .perfil-container {
            max-width: 650px;
            margin: 2rem auto;
            background: rgba(255,255,255,0.22);
            backdrop-filter: blur(40px) saturate(180%) brightness(1.05);
            -webkit-backdrop-filter: blur(40px) saturate(180%) brightness(1.05);
            border: 1px solid rgba(255,255,255,0.5);
            border-radius: 24px;
            padding: 2.5rem;
            box-shadow: 0 8px 40px rgba(8,145,178,0.15), inset 0 1px 0 rgba(255,255,255,0.7);
        }

            .perfil-container h2 {
                font-size: 1.5rem;
                margin-bottom: 1.5rem;
                border-left: 3px solid #0891b2;
                padding-left: 0.75rem;
                color: #0f172a;
            }

        .form-group {
            margin-bottom: 1.2rem;
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
        }

        .form-group label {
            display: block;
            font-size: 0.75rem;
            font-weight: 700;
            margin-bottom: 0.4rem;
            color: #475569;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .form-group input, .form-group select, .form-group textarea {
            width: 100%;
            padding: 0.7rem 0.9rem;
            background: rgba(255,255,255,0.7);
            border: 1.5px solid rgba(6,182,212,0.2);
            border-radius: 10px;
            font-family: inherit;
            font-size: 0.9rem;
            color: #0f172a;
            outline: none;
            transition: border-color 0.15s, box-shadow 0.15s, background 0.15s;
        }

        .form-group textarea {
            resize: vertical;
            min-height: 90px;
        }

            .form-group input:focus, .form-group select:focus, .form-group textarea:focus {
                border-color: #0891b2;
                background: rgba(255,255,255,0.85);
                box-shadow: 0 0 0 3px rgba(6,182,212,0.15);
            }

        .alert-mensaje {
            padding: 0.75rem 1rem;
            border-radius: 10px;
            margin-bottom: 1.5rem;
            font-size: 0.875rem;
            font-weight: 500;
        }

        .alert-success {
            background: rgba(34,197,94,0.15);
            color: #15803d;
            border: 1px solid rgba(34,197,94,0.3);
        }

        .alert-danger {
            background: rgba(239,68,68,0.15);
            color: #b91c1c;
            border: 1px solid rgba(239,68,68,0.3);
        }

        .btn-guardar {
            background: linear-gradient(135deg, #0891b2, #06b6d4);
            color: white;
            border: none;
            padding: 0.75rem 1.8rem;
            border-radius: 10px;
            cursor: pointer;
            font-weight: 600;
            font-size: 0.95rem;
            width: 100%;
            margin-top: 1rem;
            box-shadow: 0 4px 12px rgba(6,182,212,0.3);
            transition: opacity 0.15s, transform 0.1s;
        }

            .btn-guardar:hover {
                opacity: 0.95;
                transform: translateY(-1px);
            }

        .cedula-container {
            display: flex;
            gap: 0.5rem;
        }

        .btn-verificar {
            background: #0f172a;
            color: white;
            border: none;
            padding: 0 1.2rem;
            border-radius: 10px;
            cursor: pointer;
            font-weight: 600;
            font-size: 0.85rem;
            transition: background 0.15s;
            white-space: nowrap;
        }

            .btn-verificar:hover {
                background: #1e293b;
            }

        .status-resultado {
            font-size: 0.8rem;
            font-weight: 600;
            margin-top: 0.3rem;
            display: block;
        }

        .profile-avatar-wrapper {
            display: flex;
            align-items: center;
            gap: 1.25rem;
            flex-wrap: wrap;
            margin-bottom: 1.5rem;
        }

        .profile-avatar {
            width: 96px;
            height: 96px;
            border-radius: 999px;
            overflow: hidden;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(180deg, rgba(255,255,255,0.75), rgba(255,255,255,0.45));
            border: 1px solid rgba(6,182,212,0.2);
            box-shadow: 0 10px 24px rgba(6,182,212,0.12), inset 0 1px 0 rgba(255,255,255,0.75);
        }

        .profile-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

        .avatar-actions {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
            min-width: 180px;
        }

        .avatar-edit-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            padding: 0.78rem 1.2rem;
            border-radius: 999px;
            background: linear-gradient(135deg, #0891b2, #06b6d4);
            color: white;
            font-weight: 700;
            font-size: 0.95rem;
            border: none;
            cursor: pointer;
            text-decoration: none;
            box-shadow: 0 10px 22px rgba(6,182,212,0.18);
            transition: transform 0.15s, box-shadow 0.15s, background 0.15s;
        }

        .avatar-edit-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 14px 26px rgba(6,182,212,0.22);
            background: linear-gradient(135deg, #06b6d4, #0891b2);
        }

        .avatar-input {
            position: absolute;
            width: 1px;
            height: 1px;
            padding: 0;
            margin: -1px;
            overflow: hidden;
            clip: rect(0, 0, 0, 0);
            border: 0;
        }
    </style>
}
<script>
    document.addEventListener('DOMContentLoaded', function() {
        var fileInput = document.getElementById('fileAvatar');
        var img = document.getElementById('imgAvatar');
        if (!fileInput) return;

        fileInput.addEventListener('change', function (e) {
            var f = e.target.files && e.target.files[0];
            if (!f) return;

            var reader = new FileReader();
            reader.onload = function(ev) { img.src = ev.target.result; };
            reader.readAsDataURL(f);

            var form = new FormData();
            form.append('avatar', f);

            fetch('/Account/UploadAvatar', {
                method: 'POST',
                body: form
            })
            .then(function(res) {
                if (!res.ok) throw new Error('Upload failed');
                return res.json();
            })
            .then(function(data) {
                if (data && data.url) {
                    img.src = data.url;
                } else {
                    alert('No se pudo subir la imagen.');
                }
            })
            .catch(function() {
                alert('Error al subir la imagen.');
            });
        });
    });
</script>

<div class="perfil-container">
    <h2>Editar mi perfil y expediente de salud</h2>

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert-mensaje alert-success">@TempData["Mensaje"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert-mensaje alert-danger">@TempData["Error"]</div>
    }

    <form asp-action="ActualizarPerfil" method="post">
        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="Id" />

        <div class="profile-avatar-wrapper">
            <div class="profile-avatar" id="perfilAvatar">
                <img src="@userAvatarUrl" alt="Avatar" id="imgAvatar" />
            </div>
            <div class="avatar-actions">
                <label class="avatar-edit-btn" for="fileAvatar">Cambiar imagen</label>
                <input id="fileAvatar" class="avatar-input" type="file" accept="image/*" />
                <div style="font-size:0.85rem; color:var(--gray-500);">Sube una foto de perfil para tu cuenta.</div>
            </div>
        </div>

        <div class="form-group">
            <label asp-for="Nombre">Nombre completo</label>
            <input asp-for="Nombre" required placeholder="Tu nombre completo" />
        </div>

        <div class="form-group">
            <label asp-for="Email">Correo electrónico</label>
            <input asp-for="Email" type="email" required placeholder="ejemplo@vitalband.com" />
        </div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="Sexo">Género asignado</label>
                <select asp-for="Sexo">
                    <option value="Masculino">Masculino</option>
                    <option value="Femenino">Femenino</option>
                    <option value="Otro">Otro</option>
                </select>
            </div>
            <div class="form-group">
                <label asp-for="Edad">Edad actual (Calculada)</label>
                <input asp-for="Edad" type="number" readonly style="background: rgba(0,0,0,0.05); color: #64748b; cursor: not-allowed;" />
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="Peso">Peso actual (kg)</label>
                <input asp-for="Peso" type="number" step="0.1" required placeholder="ej. 75.4" />
            </div>
            <div class="form-group">
                <label asp-for="Altura">Estatura actual (m)</label>
                <input asp-for="Altura" type="number" step="0.01" required placeholder="ej. 1.72" />
            </div>
        </div>

        <input type="hidden" asp-for="MedicoAsignadoId" id="hfMedicoId" />

        <div class="form-group">
            <label asp-for="CedulaMedico">Cédula Profesional del Médico</label>
            <div class="cedula-container">
                <input asp-for="CedulaMedico" id="txtCedula" placeholder="Ej. 12345678" />
                <button type="button" class="btn-verificar" id="btnVerificarCedula">Verificar</button>
            </div>
            <span id="lblResultadoCedula" class="status-resultado"></span>
        </div>

        <div class="form-group">
            <label asp-for="HistorialMedico">Historial clínico breve</label>
            <textarea asp-for="HistorialMedico" placeholder="Indica padecimientos crónicos, cirugías previas, tipo de sangre o alergias bajo control médico..."></textarea>
        </div>

        <button type="submit" class="btn-guardar">💾 Guardar cambios clínicos</button>
    </form>
</div>
@section Scripts {
    <script>
        document.getElementById("btnVerificarCedula").addEventListener("click", function () {
            var cedulaInput = document.getElementById("txtCedula").value.trim();
            var lblResultado = document.getElementById("lblResultadoCedula");
            var hfMedicoId = document.getElementById("hfMedicoId");

            if (cedulaInput === "") {
                lblResultado.style.color = "#b91c1c";
                lblResultado.innerHTML = "Por favor, escribe una cédula primero.";
                return;
            }

            lblResultado.style.color = "#475569";
            lblResultado.innerHTML = "Buscando en VitalBand...";

            // Realizamos la consulta asíncrona al controlador
            fetch('/Configuracion/VerificarCedula?cedula=' + encodeURIComponent(cedulaInput))
                .then(response => response.json())
                .then(data => {
                    if (data.existe) {
                        lblResultado.style.color = "#15803d";
                        lblResultado.innerHTML = "✔ Médico verificado: " + data.nombre;
                        hfMedicoId.value = data.id; // Asignamos el ID encontrado al campo oculto
                    } else {
                        lblResultado.style.color = "#b91c1c";
                        lblResultado.innerHTML = data.mensaje;
                        hfMedicoId.value = ""; // Limpiamos el ID si no existe
                    }
                })
                .catch(error => {
                    lblResultado.style.color = "#b91c1c";
                    lblResultado.innerHTML = "Error al conectar con el servidor.";
                });
        });

        // Si el usuario cambia el texto de la cédula después de verificar, borramos el ID oculto para obligar a verificar de nuevo
        document.getElementById("txtCedula").addEventListener("input", function() {
            document.getElementById("hfMedicoId").value = "";
            document.getElementById("lblResultadoCedula").innerHTML = "";
        });
    </script>
}