@model IEnumerable<VitalBand.Models.UsuarioResumen>
@{
    ViewData["Title"] = "Pacientes - VitalBand";
}

@section Styles {
    <style>
        .users-container {
            max-width: 1100px;
            margin: 2rem auto;
            background: rgba(255,255,255,0.22);
            backdrop-filter: blur(40px) saturate(180%) brightness(1.05);
            -webkit-backdrop-filter: blur(40px) saturate(180%) brightness(1.05);
            border: 1px solid rgba(255,255,255,0.5);
            border-radius: 24px;
            padding: 1.75rem;
            box-shadow: 0 8px 40px rgba(8,145,178,0.15), inset 0 1px 0 rgba(255,255,255,0.7);
        }

        .users-header {
            margin-bottom: 1.5rem;
        }

            .users-header h1 {
                font-size: 1.5rem;
                font-weight: 700;
                margin-bottom: 0.25rem;
                background: linear-gradient(90deg, var(--teal-700, #0a6775), var(--teal-500, #06b6d4));
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
            }

            .users-header p {
                color: var(--gray-600);
                font-size: 0.875rem;
            }

        table {
            width: 100%;
            border-collapse: collapse;
            background: transparent;
        }

        th {
            text-align: left;
            padding: 0.75rem 0.75rem;
            font-size: 0.72rem;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            color: var(--teal-700, #0a6775);
            border-bottom: 2px solid rgba(6,182,212,0.2);
            background: transparent;
        }

        td {
            padding: 0.9rem 0.75rem;
            border-bottom: 1px solid var(--gray-50);
            vertical-align: middle;
            background: inherit;
        }

            th:nth-child(1), td:nth-child(1) {
                width: 28%;
            }

            th:nth-child(2), td:nth-child(2) {
                width: 10%;
            }

            th:nth-child(3), td:nth-child(3) {
                width: 12%;
            }

            th:nth-child(4), td:nth-child(4) {
                width: 15%;
            }

            th:nth-child(5), td:nth-child(5) {
                width: 35%;
            }

        tr.alerta-activa,
        tr.alerta-activa td {
            background-color: #FCEBEB !important;
        }

        th:nth-child(5), td:nth-child(5) {
            width: 40%;
            white-space: nowrap;
        }

        .btn-alerta {
            background: #D32F2F;
            border: none;
            color: white;
            padding: 0.4rem 1rem;
            font-weight: bold;
            box-shadow: 0 2px 5px rgba(0,0,0,0.2);
            transition: transform 0.1s;
        }

            .btn-alerta:hover {
                background: #B71C1C;
                transform: scale(1.02);
            }

        .notif-badge {
            background: #FF9800;
            color: #000;
            font-weight: bold;
        }

        .btn-accion {
            display: inline-block;
            background: rgba(6,182,212,0.1);
            border: 1px solid rgba(6,182,212,0.3);
            border-radius: 8px;
            padding: 0.35rem 0.9rem;
            font-size: 0.75rem;
            font-weight: 600;
            text-decoration: none;
            color: var(--teal-700, #0a6775);
            transition: all 0.1s;
            margin: 0 4px 0 0;
        }

            .btn-accion:hover {
                background: rgba(6,182,212,0.2);
                border-color: var(--teal-500, #06b6d4);
            }

        .btn-alerta {
            background: var(--red-600);
            border-color: var(--red-600);
            color: white;
            position: relative;
        }

            .btn-alerta:hover {
                background: var(--red-500);
            }

        .notif-badge {
            position: absolute;
            top: -6px;
            right: -6px;
            background: #ff4444;
            color: white;
            border-radius: 50%;
            width: 18px;
            height: 18px;
            font-size: 0.65rem;
            font-weight: bold;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 0 0 1px white;
        }

        .btn-inactivo {
            background: var(--gray-50);
            border-color: var(--gray-100);
            color: var(--gray-400);
            cursor: default;
            pointer-events: none;
        }

        tr.row-paciente {
            cursor: pointer;
        }

            tr.row-paciente:hover td {
                background: rgba(6,182,212,0.04);
            }

        tr.alerta-activa.row-paciente:hover td {
            background: rgba(220,38,38,0.06);
        }

        .tr-acciones {
            display: none;
        }

            .tr-acciones.visible {
                display: table-row;
            }

            .tr-acciones td {
                padding: 0.55rem 0.75rem 0.75rem 1.5rem;
                background: rgba(6,182,212,0.04);
                border-bottom: 1px solid rgba(6,182,212,0.12);
            }
    </style>
}

<div class="users-container">
    <div class="users-header">
        <h1>Pacientes monitoreados</h1>
        <p>Lista de usuarios con dispositivo VitalBand activo</p>
    </div>

    <table>
        <thead>
            <tr>
                <th>Nombre</th>
                <th>Edad</th>
                <th>Sexo</th>
                <th>Pulso promedio hoy</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr class="row-paciente @(user.TieneAlertaHoy ? "alerta-activa" : "")" onclick="toggleAcciones('@user.Id')">
                    <td><strong>@user.Nombre</strong></td>
                    <td>@user.Edad años</td>
                    <td>@user.Sexo</td>
                    <td>@user.PulsoPromedioHoy BPM</td>
                    <td>
                        @if (user.TieneAlertaHoy)
                        {
                            <a asp-controller="AtenderAlerta" asp-action="Index" asp-route-alertaId="@user.Id"
                               class="btn-accion btn-alerta" style="position:relative; background:#D32F2F; color:white; font-weight:bold;"
                               onclick="event.stopPropagation()">
                                Atender alerta
                                <span class="notif-badge">1</span>
                            </a>
                        }
                        else
                        {
                            <span class="btn-accion btn-inactivo">Sin alertas</span>
                        }
                    </td>
                </tr>
                <tr class="tr-acciones" id="acciones-@user.Id">
                    <td colspan="5">
                        <a asp-controller="DatosGenerales" asp-action="Index" asp-route-id="@user.Id" class="btn-accion" onclick="event.stopPropagation()">Ver registros</a>
                        <a asp-controller="HistorialAlertas" asp-action="Index" asp-route-usuarioId="@user.Id" class="btn-accion" onclick="event.stopPropagation()">Historial alertas</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        function toggleAcciones(id) {
            const tr = document.getElementById('acciones-' + id);
            if(tr) {
                tr.classList.toggle('visible');
            }
        }
    </script>
}