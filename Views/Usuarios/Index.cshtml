@model IEnumerable<VitalBand.Models.UsuarioResumen>
@{
    ViewData["Title"] = "Pacientes - VitalBand";
}

@section Styles {
    <style>
        @@media (min-width: 992px) {
            body {
                overflow: hidden;
            }

            .vb-content.container {
                max-width: 100% !important;
                width: 100% !important;
                padding: 0 !important;
                margin: 0 !important;
                height: calc(100vh - 122px);
                display: flex;
                align-items: stretch;
            }

            .vb-content main {
                width: 100%;
                height: 100%;
            }
        }

        .dashboard-split {
            display: flex;
            flex-direction: column;
            width: 100%;
            height: 100%;
        }

        @@media (min-width: 992px) {
            .dashboard-split {
                flex-direction: row;
            }
        }

        .dash-sidebar {
            flex: 0.35;
            background: linear-gradient(145deg, #09333f 0%, #0d4856 60%, #115e59 100%);
            padding: 3rem 2.5rem;
            display: flex;
            flex-direction: column;
            justify-content: flex-start;
            gap: 1.5rem;
            color: var(--white);
            border-right: 1px solid rgba(255,255,255,0.08);
        }

        .sidebar-header h2 {
            font-size: 1.4rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 0.5rem;
        }

        .sidebar-header p {
            font-size: 0.88rem;
            color: rgba(255, 255, 255, 0.65);
            line-height: 1.4;
        }

        .sidebar-divider {
            border: none;
            border-top: 1px solid rgba(255,255,255,0.12);
            margin: 0.5rem 0;
        }

        .metric-card-mini {
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 16px;
            padding: 1.25rem;
            display: flex;
            align-items: center;
            gap: 15px;
        }

            .metric-card-mini .icon {
                font-size: 1.5rem;
                background: rgba(255,255,255,0.08);
                width: 3rem;
                height: 3rem;
                display: flex;
                align-items: center;
                justify-content: center;
                border-radius: 12px;
            }

            .metric-card-mini.alert-active-bg {
                background: rgba(220, 38, 38, 0.1);
                border-color: rgba(220, 38, 38, 0.2);
            }

                .metric-card-mini.alert-active-bg .icon {
                    background: rgba(220, 38, 38, 0.2);
                }

        .metric-info span {
            display: block;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: rgba(255, 255, 255, 0.5);
        }

        .metric-info strong {
            font-size: 1.35rem;
            font-weight: 700;
        }

        .dash-main-content {
            flex: 1.65;
            padding: 3rem 4rem;
            background: #fafbfc;
            display: flex;
            flex-direction: column;
            overflow-y: auto;
        }

        .table-title-area {
            margin-bottom: 2rem;
        }

            .table-title-area h1 {
                font-size: 1.65rem;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                color: var(--gray-900);
                margin-bottom: 0.25rem;
            }

            .table-title-area p {
                color: var(--gray-600);
                font-size: 0.92rem;
            }

        .vb-table-responsive {
            width: 100%;
            background: var(--white);
            border: 1px solid var(--gray-200);
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 4px 20px rgba(0,0,0,0.01);
        }

        .vb-patient-table {
            width: 100%;
            border-collapse: collapse;
        }

            .vb-patient-table th {
                background: #f8fafc !important;
                color: var(--teal-700) !important;
                font-size: 0.75rem !important;
                font-weight: 700 !important;
                text-transform: uppercase;
                letter-spacing: 0.8px;
                padding: 1rem 1.25rem !important;
                border-bottom: 1.5px solid var(--gray-200) !important;
            }

            .vb-patient-table td {
                padding: 1.1rem 1.25rem !important;
                border-bottom: 1px solid var(--gray-100) !important;
                vertical-align: middle;
                font-size: 0.92rem;
                color: var(--gray-700);
            }

            .vb-patient-table tr td:first-child {
                border-left: 4px solid transparent;
            }

            .vb-patient-table tr.normal-active:hover td {
                background-color: #f8fafc;
            }

            .vb-patient-table tr.normal-active td:first-child {
                border-left-color: var(--teal-500);
            }

            .vb-patient-table tr.alerta-activa td {
                background-color: #fff5f5;
            }

                .vb-patient-table tr.alerta-activa td:first-child {
                    border-left-color: var(--red-600);
                }

            .vb-patient-table tr.alerta-activa:hover td {
                background-color: #fef2f2;
            }

        .actions-cell-wrapper {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .btn-action-outline {
            display: inline-flex;
            align-items: center;
            padding: 0.5rem 0.95rem;
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--teal-700);
            background-color: var(--white);
            border: 1.5px solid var(--gray-300);
            border-radius: 10px;
            text-decoration: none !important;
            transition: all 0.15s ease;
        }

            .btn-action-outline:hover {
                color: var(--teal-700);
                border-color: var(--teal-600);
                background-color: rgba(13, 148, 136, 0.04);
                transform: translateY(-1px);
            }

        .btn-alert-danger {
            display: inline-flex;
            align-items: center;
            padding: 0.5rem 1.1rem;
            font-size: 0.8rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--white);
            background: linear-gradient(135deg, var(--red-600), #b91c1c);
            border: none;
            border-radius: 10px;
            text-decoration: none !important;
            box-shadow: 0 4px 12px rgba(220, 38, 38, 0.15);
            transition: all 0.15s ease;
        }

            .btn-alert-danger:hover {
                color: var(--white);
                opacity: 0.92;
                box-shadow: 0 6px 16px rgba(220, 38, 38, 0.28);
                transform: translateY(-1px);
            }

        .badge-pulse {
            background-color: var(--white);
            color: var(--red-600);
            font-size: 0.7rem;
            font-weight: 800;
            border-radius: 50%;
            width: 16px;
            height: 16px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin-left: 6px;
        }

        .status-pill-safe {
            display: inline-flex;
            font-size: 0.75rem;
            font-weight: 600;
            color: var(--teal-700);
            background: var(--teal-100);
            padding: 0.25rem 0.65rem;
            border-radius: 20px;
        }

        @@media (max-width: 991px) {
            .dash-main-content, .dash-sidebar {
                padding: 2rem 1.5rem;
            }
        }
    </style>
}

<div class="dashboard-split">
    <div class="dash-sidebar">
        <div class="sidebar-header">
            <h2>VitalBand Core</h2>
            <p>Ecosistema de monitoreo en tiempo real para especialistas autorizados.</p>
        </div>

        <hr class="sidebar-divider" />

        <div class="metric-card-mini">
            <div class="icon">🩺</div>
            <div class="metric-info">
                <span>Total Pacientes</span>
                <strong>@Model.Count() asignados</strong>
            </div>
        </div>

        @{
            var alertasActivas = Model.Count(u => u.TieneAlertaHoy);
        }
        <div class="metric-card-mini @(alertasActivas > 0 ? "alert-active-bg" : "")">
            <div class="icon">🚨</div>
            <div class="metric-info">
                <span>Alertas Críticas</span>
                <strong style="color: @(alertasActivas > 0 ? "var(--red-500)" : "inherit")">
                    @alertasActivas pendientes
                </strong>
            </div>
        </div>

        <div class="metric-card-mini">
            <div class="icon">⚡</div>
            <div class="metric-info">
                <span>Servidor de Señales</span>
                <strong style="color: var(--teal-400);">En Línea Activo</strong>
            </div>
        </div>
    </div>

    <div class="dash-main-content">
        <div class="table-title-area">
            <h1>Pacientes Monitoreados</h1>
            <p>Monitoreo proactivo de frecuencia cardíaca e incidentes diarios</p>
        </div>

        <div class="vb-table-responsive">
            <table class="vb-patient-table">
                <thead>
                    <tr>
                        <th style="width: 26%;">Nombre Completo</th>
                        <th style="width: 12%;">Edad</th>
                        <th style="width: 12%;">Sexo</th>
                        <th style="width: 18%;">Pulso Promedio</th>
                        <th style="width: 32%;">Acciones Inmediatas</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr class="@(user.TieneAlertaHoy ? "alerta-activa" : "normal-active")">
                            <td><strong>@user.Nombre</strong></td>
                            <td>@user.Edad años</td>
                            <td>@user.Sexo</td>
                            <td>
                                <span style="font-weight: 600; color: @(user.TieneAlertaHoy ? "var(--red-600)" : "var(--gray-900)");">
                                    @user.PulsoPromedioHoy BPM
                                </span>
                            </td>
                            <td>
                                <div class="actions-cell-wrapper">
                                    <a asp-controller="DatosGenerales" asp-action="Index" asp-route-id="@user.Id" class="btn-action-outline">
                                        📈 Registros
                                    </a>
                                    <a asp-controller="HistorialAlertas" asp-action="Index" asp-route-usuarioId="@user.Id" class="btn-action-outline">
                                        📋 Historial
                                    </a>

                                    @if (user.TieneAlertaHoy)
                                    {
                                        <a asp-controller="AtenderAlerta" asp-action="Index" asp-route-alertaId="@user.AlertaIdPendiente" class="btn-alert-danger">
                                            🚨 Atender <span class="badge-pulse">1</span>
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="status-pill-safe">💚 Estable</span>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>