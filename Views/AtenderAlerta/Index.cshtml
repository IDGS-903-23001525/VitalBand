@model VitalBand.Models.AtenderAlerta
@{
    ViewData["Title"] = "Atender alerta - VitalBand";
}

@section Styles {
    <style>
        .atender-container {
            max-width: 900px;
            margin: 2rem auto;
            background: rgba(255,255,255,0.22);
            backdrop-filter: blur(40px) saturate(180%) brightness(1.05);
            -webkit-backdrop-filter: blur(40px) saturate(180%) brightness(1.05);
            border: 1px solid rgba(255,255,255,0.5);
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 8px 40px rgba(8,145,178,0.15), inset 0 1px 0 rgba(255,255,255,0.7);
        }

        /* 🛠️ CORRECCIÓN: Evaluamos de forma segura si es true */
        .alerta-header {
            padding: 1rem 1.5rem;
            background: @(Model.Atendida == true ? "var(--gray-50)" : "var(--red-50)");
            border-bottom: 1px solid var(--gray-100);
        }

            .alerta-header h2 {
                font-size: 1.25rem;
                font-weight: 600;
                color: @(Model.Atendida == true ? "var(--gray-900)" : "var(--red-600)");
            }

        .mapa-placeholder {
            background: var(--gray-100);
            height: 250px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            font-family: monospace;
            border-bottom: 1px solid var(--gray-200);
        }

        .info-alerta {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
            padding: 1.5rem;
        }

        .dato {
            background: rgba(255,255,255,0.55);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border: 1px solid rgba(6,182,212,0.15);
            border-radius: 12px;
            padding: 0.85rem;
            box-shadow: 0 2px 10px rgba(8,145,178,0.06);
        }

            .dato label {
                font-size: 0.7rem;
                text-transform: uppercase;
                color: var(--gray-600);
                display: block;
                margin-bottom: 4px;
            }

            .dato strong {
                font-size: 1rem;
            }

        .respuesta {
            grid-column: span 2;
        }

        .acciones {
            padding: 1rem 1.5rem 1.5rem;
            display: flex;
            justify-content: flex-end;
            gap: 1rem;
            border-top: 1px solid var(--gray-100);
        }

        .btn {
            padding: 0.5rem 1.2rem;
            border-radius: 6px;
            text-decoration: none;
            font-weight: 500;
            border: none;
            cursor: pointer;
            font-family: inherit;
        }

        .btn-secundario {
            background: rgba(255,255,255,0.6);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            border: 1.5px solid rgba(6,182,212,0.2);
            color: var(--gray-700, #334155);
            border-radius: 10px;
        }

            .btn-secundario:hover {
                background: rgba(255,255,255,0.85);
            }

        .btn-primario {
            background: linear-gradient(135deg, #0891b2, #06b6d4);
            color: white;
            box-shadow: 0 2px 8px rgba(6,182,212,0.3);
        }

        .btn-peligro {
            /* Glassy, compact danger button that harmonizes with the palette */
            padding: 0.4rem 0.9rem;
            font-size: 0.95rem;
            border-radius: 999px;
            color: var(--red-700);
            background: linear-gradient(180deg, rgba(254,202,202,0.22), rgba(254,226,226,0.12));
            border: 1px solid rgba(239,68,68,0.18);
            backdrop-filter: blur(6px) saturate(120%);
            -webkit-backdrop-filter: blur(6px) saturate(120%);
            box-shadow: 0 6px 18px rgba(239,68,68,0.10), inset 0 1px 0 rgba(255,255,255,0.35);
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            transition: transform 120ms ease, box-shadow 120ms ease, background 120ms ease;
        }

        .btn-peligro:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 26px rgba(239,68,68,0.18), inset 0 1px 0 rgba(255,255,255,0.45);
            background: linear-gradient(180deg, rgba(239,68,68,0.18), rgba(239,68,68,0.06));
            color: white;
        }

        .btn-peligro:active { transform: translateY(0); }

        /* Optional small numeric badge inside the button */
        .btn-peligro .badge {
            background: rgba(220,38,38,0.95);
            color: white;
            min-width: 18px;
            height: 18px;
            border-radius: 999px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 0.7rem;
            padding: 0 4px;
            box-shadow: 0 2px 6px rgba(0,0,0,0.12);
        }
    </style>
}

<div class="atender-container">
    <div class="alerta-header">
        <h2>@(Model.Atendida == true ? "Alerta atendida" : "¡Nueva alerta! Requiere atención")</h2>
    </div>

    <div class="mapa-placeholder">
        <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#0891b2" stroke-width="1.5">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
            <circle cx="12" cy="10" r="3" />
        </svg>
        <p><strong>Ubicación:</strong> Lat @Model.Latitud, Lng @Model.Longitud</p>
        <small>(Integración con mapa real)</small>
    </div>

    <div class="info-alerta">
        <div class="dato">
            <label>Pulso registrado</label>
            <strong>@Model.PulsoRegistrado BPM</strong>
        </div>
        <div class="dato">
            <label>Duración del episodio</label>
            <strong>@Model.DuracionSegundos segundos</strong>
        </div>
        <div class="dato">
            <label>Fecha y hora</label>
            <strong>@(Model.FechaHoraAlerta.HasValue ? Model.FechaHoraAlerta.Value.ToString("dd/MM/yyyy HH:mm") : "Sin fecha")</strong>
        </div>
        <div class="dato">
            <label>Estado</label>
            <strong>@(Model.Atendida == true ? "Atendida" : "Pendiente")</strong>
        </div>
        <div class="dato respuesta">
            <label>Respuesta del paciente</label>
            <strong>@Model.RespuestaUsuario</strong>
        </div>
    </div>

    <div class="acciones">
        <a asp-controller="HistorialAlertas" asp-action="Index" asp-route-usuarioId="@ViewBag.UsuarioId" class="btn btn-secundario">Volver al historial</a>

        @if (Model.Atendida != true)
        {
            <form asp-action="MarcarAtendida" asp-controller="AtenderAlerta" method="post" style="margin:0;">
                @Html.AntiForgeryToken()

                <!-- 🛠️ CORRECCIÓN: Cambia name="alertaId" por name="id" -->
                <input type="hidden" name="id" value="@Model.AlertaId" />

                <button type="submit" class="btn btn-peligro">Marcar como atendida</button>
            </form>
        }
    </div>
</div>