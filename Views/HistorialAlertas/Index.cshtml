@model IEnumerable<VitalBand.Models.AlertaHistorial>
@{
    ViewData["Title"] = "Historial de alertas - VitalBand";
}

@section Styles {
    <style>
        .alertas-container {
            max-width: 1100px;
            margin: 2rem auto;
            background: rgba(255,255,255,0.22);
            backdrop-filter: blur(40px) saturate(180%) brightness(1.05);
            -webkit-backdrop-filter: blur(40px) saturate(180%) brightness(1.05);
            border: 1px solid rgba(255,255,255,0.5);
            border-radius: 24px;
            padding: 1.75rem;
            box-shadow: 0 8px 40px rgba(8,145,178,0.15), inset 0 1px 0 rgba(255,255,255,0.7);
        }

        .alertas-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
        }

            .alertas-header h1 {
                font-size: 1.5rem;
                font-weight: 600;
            }

        .btn-volver {
            background: linear-gradient(135deg, #0891b2, #06b6d4);
            color: white;
            padding: 0.4rem 1rem;
            border-radius: 8px;
            text-decoration: none;
            font-size: 0.875rem;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th {
            text-align: left;
            padding: 0.75rem 0.5rem;
            font-size: 0.75rem;
            text-transform: uppercase;
            color: var(--gray-600);
            border-bottom: 1px solid var(--gray-100);
        }

        td {
            padding: 0.8rem 0.5rem;
            border-bottom: 1px solid var(--gray-50);
        }

        .badge-respondida {
            background: var(--green-50);
            color: var(--green-600);
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 500;
        }

        .badge-pendiente {
            background: var(--red-50);
            color: var(--red-600);
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 500;
        }
    </style>
}

<div class="alertas-container">
    <div class="alertas-header">
        <h1>Alertas registradas</h1>
        <a asp-controller="Usuarios" asp-action="Index" class="btn-volver">Volver</a>
    </div>

    <table>
        <thead>
            <tr>
                <th>Fecha y hora</th>
                <th>Ubicación</th>
                <th>Estado</th>
                <th>Descripción</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var alerta in Model)
            {
                <tr>
                    <td>@alerta.FechaHora.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@alerta.Ubicacion</td>
                    <td>
                        @if (alerta.Respondida == true)
                        {
                            <span class="badge-respondida">Respondida</span>
                        }
                        else
                        {
                            <span class="badge-pendiente">Pendiente</span>
                        }
                    </td>
                    <td>@alerta.DescripcionEvento</td>
                </tr>
            }
        </tbody>
    </table>
</div>