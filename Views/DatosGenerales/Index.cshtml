@using System.Linq
@model VitalBand.Models.DatosGenerales
@{
    ViewData["Title"] = $"Datos de {Model.Nombre} - VitalBand";
    var rangos = ViewBag.RangosPulso as List<VitalBand.Models.RangoPulso>;
}
@functions {
    string ObtenerClasePulso(int pulso)
    {
        if (pulso < 50 || pulso > 110) return "lectura-critica";
        if ((pulso >= 50 && pulso < 60) || (pulso > 100 && pulso <= 110)) return "lectura-precaucion";
        return "lectura-normal";
    }
}

@section Styles {
    <style>
        .datos-container {
            max-width: 1200px;
            width: 92%;
            margin: 1.5rem auto;
            background: rgba(255,255,255,0.22);
            backdrop-filter: blur(40px) saturate(180%) brightness(1.05);
            -webkit-backdrop-filter: blur(40px) saturate(180%) brightness(1.05);
            border: 1px solid rgba(255,255,255,0.5);
            border-radius: 24px;
            box-shadow: 0 8px 40px rgba(8,145,178,0.15), inset 0 1px 0 rgba(255,255,255,0.7);
        }

        @@media (min-width: 768px) {
            .datos-container {
                margin: 2.5rem auto;
            }
        }

        .datos-header {
            padding: 2.2rem 2rem;
            border-bottom: 1px solid rgba(255,255,255,0.25);
            background: linear-gradient(135deg, rgba(9, 51, 63, 0.95) 0%, rgba(13, 72, 86, 0.9) 100%);
            border-radius: 24px 24px 0 0;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 1.5rem;
        }

        .header-left-brand {
            display: flex;
            align-items: center;
            gap: 1.5rem;
        }

        .datos-avatar .avatar {
            width: 96px; 
            height: 96px;
            border-radius: 50%;
            overflow: hidden;
            border: 3px solid #0d9488;
            box-shadow: 0 8px 24px rgba(9, 51, 63, 0.3);
            background-color: #ffffff;
            transition: transform 0.2s ease;
        }

            .datos-avatar .avatar:hover {
                transform: scale(1.03);
            }

            .datos-avatar .avatar img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        .header-patient-info h2 {
            font-size: 1.6rem;
            font-weight: 700;
            margin: 0 0 0.25rem 0;
            color: #ffffff;
            letter-spacing: -0.5px;
        }

        .header-patient-info p {
            font-size: 0.875rem;
            color: #2dd4bf;
            margin: 0;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .header-right-controls {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            gap: 0.8rem;
        }

        @@media (max-width: 768px) {
            .header-left-brand {
                flex-direction: column;
                align-items: center;
                text-align: center;
                width: 100%;
            }

            .header-right-controls {
                width: 100%;
                align-items: center;
            }
        }

        .info-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 0;
            padding: 0;
            border-bottom: 1px solid rgba(255,255,255,0.2);
            background: rgba(255, 255, 255, 0.15);
        }

        .info-item {
            padding: 1.25rem 1.5rem;
            border-bottom: 1px solid rgba(0,0,0,0.05);
            transition: background 0.15s;
        }

        @@media (min-width: 576px) {
            .info-item {
                border-right: 1px solid rgba(0,0,0,0.05);
            }
        }

        .info-item:hover {
            background: rgba(255,255,255,0.3);
        }

        .info-item:last-child {
            border-right: none;
            border-bottom: none;
        }

        .info-item label {
            font-size: 0.68rem;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            color: #64748b;
            display: block;
            margin-bottom: 3px;
            font-weight: 700;
        }

        .info-item .value {
            font-weight: 600;
            font-size: 0.95rem;
            color: #1e293b;
        }

        .chart-card {
            padding: 1.5rem;
            border-bottom: 1px solid rgba(255,255,255,0.2);
            background: #ffffff;
        }

        @@media (min-width: 768px) {
            .chart-card {
                padding: 1.75rem 2rem;
            }
        }

        .chart-card h4 {
            font-size: 0.72rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #0891b2;
            margin-bottom: 1rem;
        }

        canvas {
            width: 100% !important;
            height: auto !important;
            max-height: 240px;
        }

        .lecturas-lista {
            padding: 1.5rem;
        }

        @@media (min-width: 768px) {
            .lecturas-lista {
                padding: 1.25rem 2rem 1.5rem;
            }
        }

        .lecturas-lista h4 {
            font-size: 0.8rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            color: #475569;
            margin: 0 0 0.875rem;
        }

        .lecturas-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 0.6rem;
        }

        @@media (min-width: 576px) {
            .lecturas-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @@media (min-width: 992px) {
            .lecturas-grid {
                grid-template-columns: repeat(3, 1fr);
            }
        }

        .lectura-item {
            display: flex;
            flex-direction: row;
            align-items: center;
            justify-content: space-between;
            padding: 0.7rem 1rem;
            border-radius: 12px;
            font-size: 0.875rem;
            transition: all 0.15s ease;
        }

            .lectura-item:hover {
                box-shadow: 0 4px 12px rgba(15, 23, 42, 0.06);
                transform: translateY(-1px);
            }

            .lectura-item span {
                color: #64748b;
                font-size: 0.75rem;
                font-weight: 600;
            }

            .lectura-item strong {
                font-weight: 700;
                font-size: 0.95rem;
            }

        .lectura-normal {
            background: rgba(16,185,129,0.09);
            border: 1.5px solid rgba(16,185,129,0.3);
        }

            .lectura-normal strong {
                color: #065f46;
            }

        .lectura-precaucion {
            background: rgba(245,158,11,0.09);
            border: 1.5px solid rgba(245,158,11,0.3);
        }

            .lectura-precaucion strong {
                color: #92400e;
            }

        .lectura-critica {
            background: rgba(220,38,38,0.09);
            border: 1.5px solid rgba(220,38,38,0.3);
        }

            .lectura-critica strong {
                color: #991b1b;
            }

        .btn-accion {
            display: inline-block;
            background: rgba(255,255,255,0.15);
            border: 1px solid rgba(255,255,255,0.25);
            border-radius: 8px;
            padding: 0.4rem 1rem;
            font-size: 0.8rem;
            font-weight: 600;
            text-decoration: none;
            color: #ffffff;
            transition: all 0.15s;
            cursor: pointer;
        }

            .btn-accion:hover {
                background: #0d9488;
                border-color: #2dd4bf;
            }

            .btn-accion:disabled, #selectedDate:disabled {
                opacity: 0.4;
                cursor: not-allowed;
                background: rgba(255,255,255,0.05);
                border-color: rgba(255,255,255,0.1);
                color: rgba(255,255,255,0.4);
            }

        .footer-actions {
            padding: 1.25rem 1.5rem;
            display: flex;
            justify-content: flex-end;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 0 0 24px 24px;
        }

        .btn-volver {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: linear-gradient(135deg, #0f766e, #0d9488);
            color: white;
            border: none;
            border-radius: 10px;
            padding: 0.55rem 1.3rem;
            font-size: 0.85rem;
            font-weight: 600;
            text-decoration: none;
            box-shadow: 0 4px 14px rgba(13, 148, 136, 0.2);
            transition: all 0.15s ease;
        }

            .btn-volver:hover {
                transform: translateY(-1px);
                box-shadow: 0 6px 18px rgba(13, 148, 136, 0.3);
                color: white;
            }

        .vb-fab-alerta {
            position: fixed;
            bottom: 1.25rem;
            right: 1.25rem;
            z-index: 999;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #b91c1c, #ef4444);
            color: white;
            border: none;
            border-radius: 50%;
            width: 52px;
            height: 52px;
            cursor: pointer;
            box-shadow: 0 4px 14px rgba(220,38,38,0.45);
            transition: transform 0.15s, box-shadow 0.15s;
        }

            .vb-fab-alerta:hover {
                transform: translateY(-2px) scale(1.05);
                box-shadow: 0 8px 24px rgba(220,38,38,0.5);
            }

            .vb-fab-alerta svg {
                width: 22px;
                height: 22px;
            }

        .vb-fab-label {
            display: none;
        }

        .vb-fab-pulse {
            position: absolute;
            inset: 0;
            border-radius: 50%;
            background: rgba(220,38,38,0.38);
            animation: vb-pulse 2.2s ease-out infinite;
            pointer-events: none;
        }

        @@keyframes vb-pulse {
            0% {
                transform: scale(1);
                opacity: 0.65;
            }

            70% {
                transform: scale(1.22);
                opacity: 0;
            }

            100% {
                transform: scale(1.22);
                opacity: 0;
            }
        }

        .modal-confirm {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(15,23,42,0.45);
            backdrop-filter: blur(4px);
            justify-content: center;
            align-items: center;
            z-index: 1000;
        }

        .modal-content {
            background: rgba(255,255,255,0.95);
            backdrop-filter: blur(20px);
            border-radius: 20px;
            border: 1px solid rgba(6,182,212,0.18);
            max-width: 380px;
            width: 90%;
            padding: 2rem;
            text-align: center;
            box-shadow: 0 24px 64px rgba(0,0,0,0.14);
        }

            .modal-content p {
                font-size: 0.95rem;
                line-height: 1.6;
                margin-bottom: 1.5rem;
                color: #334155;
            }

        .modal-buttons {
            display: flex;
            gap: 0.75rem;
            justify-content: center;
        }

        .modal-btn {
            padding: 0.55rem 1.25rem;
            border-radius: 9px;
            border: none;
            font-size: 0.875rem;
            font-weight: 600;
            cursor: pointer;
            transition: opacity 0.15s;
        }

            .modal-btn:hover {
                opacity: 0.85;
            }

        .modal-btn-confirm {
            background: linear-gradient(135deg, #b91c1c, #ef4444);
            color: white;
        }

        .modal-btn-cancel {
            background: #e2e8f0;
            color: #334155;
        }
    </style>
}

<div class="datos-container">
    <div class="datos-header">
        <div class="header-left-brand">
            <div class="datos-avatar">
                <div class="avatar" id="pacienteAvatar">
                    <img src="/img/pacientes/@(Model.UsuarioId).jpg" id="imgPacienteAvatar" alt="Foto de @Model.Nombre" onerror="this.onerror=null; this.src='/img/avatar-placeholder.png';" />
                </div>
            </div>
            <div class="header-patient-info">
                <h2>@Model.Nombre</h2>
                <p>Expediente Médico · Telemetría IoT Activa</p>
            </div>
        </div>

        <div class="header-right-controls">
            @{
                var esMedico = User.IsInRole("Medico") || User.IsInRole("medico");
            }
            <div style="display:flex; gap:0.5rem; align-items:center;">
                <button type="button" id="btnPrevDay" class="btn-accion" title="Día anterior" @(esMedico ? "" : "disabled")>◀</button>
                <input type="date" id="selectedDate" value="@(ViewBag.FechaSeleccionada ?? DateTime.Today.ToString("yyyy-MM-dd"))" style="padding:6px 12px; border-radius:8px; border:1px solid rgba(255,255,255,0.25); background: rgba(255,255,255,0.9); font-weight: 600; color: #09333f;" @(esMedico ? "" : "disabled") />
                <button type="button" id="btnNextDay" class="btn-accion" title="Siguiente día" @(esMedico ? "" : "disabled")>▶</button>
            </div>
            <input type="hidden" id="hdnEsMedico" value="@(User.IsInRole("Medico") || User.IsInRole("medico") ? "true" : "false")" />
        </div>
    </div>

    <div class="info-grid">
        <div class="info-item"><label>Edad</label><div class="value">@Model.Edad años</div></div>
        <div class="info-item"><label>Género</label><div class="value">@Model.Genero</div></div>
        <div class="info-item"><label>Descripción médica</label><div class="value">@Model.DescripcionMedica</div></div>
        <div class="info-item"><label>Registro</label><div class="value">@Model.FechaRegistro.ToString("dd/MM/yyyy")</div></div>
        <div class="info-item"><label>Total alertas</label><div class="value">@Model.TotalAlertas</div></div>
    </div>

    <div class="chart-card">
        <h4>Frecuencia cardíaca — últimas 24h</h4>
        <div style="width: 100%; position: relative;">
            <canvas id="pulseChart"></canvas>
        </div>
    </div>

    <div class="lecturas-lista">
        <h4>Lecturas horarias</h4>
        <div class="lecturas-grid" id="lecturasGrid">
            <p style="grid-column: 1 / -1; text-align: center; color: #94a3b8;">Cargando signos vitales en tiempo real...</p>
        </div>

        @if (User.IsInRole("Medico"))
        {
            <input type="hidden" id="hdnPatientId" value="@Model.PacienteId" />
        }
    </div>

    <div class="footer-actions">
        <a asp-controller="Usuarios" asp-action="Index" class="btn-volver">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6" /></svg>
            Volver a pacientes
        </a>
    </div>
</div>

<div id="modalConfirmacion" class="modal-confirm" aria-hidden="true" role="dialog" aria-modal="true">
    <div class="modal-content">
        @Html.AntiForgeryToken()
        <p>¿Estás seguro de activar una alerta manual para este paciente?</p>
        <div class="modal-buttons">
            <button type="button" class="modal-btn modal-btn-cancel" id="btnCancelar">Cancelar</button>
            <button type="button" class="modal-btn modal-btn-confirm" id="btnConfirmar">Sí, activar</button>
        </div>
    </div>
</div>

@if (User.IsInRole("Medico"))
{
    <button type="button" class="vb-fab-alerta" id="btnAbrirModal" title="Activar alerta manual">
        <span class="vb-fab-pulse"></span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
            <line x1="12" y1="9" x2="12" y2="13" />
            <line x1="12" y1="17" x2="12.01" y2="17" />
        </svg>
        <span class="vb-fab-label">Activar alerta manual</span>
    </button>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var esMedicoStr = document.getElementById('hdnEsMedico') ? document.getElementById('hdnEsMedico').value : "false";
            var esMedico = esMedicoStr === "true";

            var input = document.getElementById('selectedDate');
            var btnPrev = document.getElementById('btnPrevDay');
            var btnNext = document.getElementById('btnNextDay');

            function obtenerFechaDelInput() {
                if (!input || !input.value) return new Date();
                var partes = input.value.split('-'); 
                return new Date(parseInt(partes[0]), parseInt(partes[1]) - 1, parseInt(partes[2]));
            }

            function navigateToDate(d) {
                var y = d.getFullYear();
                var m = String(d.getMonth() + 1).padStart(2, '0');
                var day = String(d.getDate()).padStart(2, '0');
                var fechaStr = y + '-' + m + '-' + day;

                if (input) input.value = fechaStr;
                cargarMetricasRealtime();
            }

            if (btnPrev) btnPrev.addEventListener('click', function() {
                if (!esMedico) return;
                var cur = obtenerFechaDelInput();
                cur.setDate(cur.getDate() - 1);
                navigateToDate(cur);
            });

            if (btnNext) btnNext.addEventListener('click', function() {
                if (!esMedico) return;
                var cur = obtenerFechaDelInput();
                cur.setDate(cur.getDate() + 1);
                navigateToDate(cur);
            });

            if (input) input.addEventListener('change', function() {
                if (!esMedico) return;
                var cur = obtenerFechaDelInput();
                navigateToDate(cur);
            });
        });

        const ctx = document.getElementById('pulseChart').getContext('2d');
        let pulseChart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: [],
                datasets: [{
                    label: 'Pulso (BPM)',
                    data: [],
                    borderColor: '#0d9488',
                    backgroundColor: 'rgba(13,148,136,0.05)',
                    tension: 0.3,
                    fill: true
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } }
            }
        });
        function obtenerClasePulso(pulso) {
        if (pulso < 50 || pulso > 110) return "lectura-critica";
        if ((pulso >= 50 && pulso < 60) || (pulso > 100 && pulso <= 110)) return "lectura-precaucion";
        return "lectura-normal";
        }
        async function cargarMetricasRealtime() {
            const userId = '@Model.UsuarioId';
            const grid = document.getElementById('lecturasGrid');
            const fechaSeleccionada = document.getElementById('selectedDate').value;
            
            try {
                const response = await fetch(`/api/VitalSign/hoy/${encodeURIComponent(userId)}?fecha=${encodeURIComponent(fechaSeleccionada)}`);
                if (!response.ok) throw new Error('Error en la respuesta de la API');
                
                const datos = await response.json();

                if (datos.length === 0) {
                    grid.innerHTML = '<p style="grid-column: 1 / -1; text-align: center; color: #94a3b8;">No se encontraron lecturas registradas en esta fecha.</p>';
                    pulseChart.data.labels = [];
                    pulseChart.data.datasets[0].data = [];
                    pulseChart.update();
                    return;
                }

                const labelsHoras = datos.map(item => {
                    const d = new Date(item.fecha);
                    return String(d.getHours()).padStart(2, '0') + ':' + String(d.getMinutes()).padStart(2, '0');
                });

                const valoresBpm = datos.map(item => item.bpm);

                pulseChart.data.labels = labelsHoras;
                pulseChart.data.datasets[0].data = valoresBpm;
                pulseChart.update();

                grid.innerHTML = '';
                datos.forEach((item, index) => {
                    const horaFormateada = labelsHoras[index];
                    const claseColor = obtenerClasePulso(item.bpm);

                    const itemHtml = `
                        <div class="lectura-item ${claseColor}">
                            <span>${horaFormateada} hrs</span>
                            <strong>${item.bpm} BPM</strong>
                        </div>
                    `;
                    grid.insertAdjacentHTML('beforeend', itemHtml);
                });

            } catch (error) {
                console.error('[Error Realtime API]:', error);
                grid.innerHTML = '<p style="grid-column: 1 / -1; text-align: center; color: #b91c1c;">Hubo un problema al conectar con el servidor de telemetría.</p>';
            }
        }

        document.addEventListener('DOMContentLoaded', () => {
            cargarMetricasRealtime();
            setInterval(cargarMetricasRealtime, 120000);
        });

        const modal = document.getElementById('modalConfirmacion');
        const btnAbrir = document.getElementById('btnAbrirModal');
        const btnCancelar = document.getElementById('btnCancelar');
        const btnConfirmar = document.getElementById('btnConfirmar');

        if (btnAbrir) {
            btnAbrir.addEventListener('click', function() {
                const patientId = document.getElementById('hdnPatientId').value;
                modal.setAttribute('data-patientId', patientId);
                modal.style.display = 'flex';
            });
        }

        if (btnCancelar) {
            btnCancelar.addEventListener('click', function() { modal.style.display = 'none'; });
        }

        if (btnConfirmar) {
            btnConfirmar.addEventListener('click', function() {
                const patientId = modal.getAttribute('data-patientId');
                const tokenInput = document.querySelector('#modalConfirmacion input[name="__RequestVerificationToken"]');

                const form = document.createElement('form');
                form.method = 'post';
                form.action = '@Url.Action("ActivateManualAlert", "DatosGenerales")';

                if (tokenInput) {
                    const inputToken = document.createElement('input');
                    inputToken.type = 'hidden';
                    inputToken.name = '__RequestVerificationToken';
                    inputToken.value = tokenInput.value;
                    form.appendChild(inputToken);
                }

                const inputPatientId = document.createElement('input');
                inputPatientId.type = 'hidden';
                inputPatientId.name = 'patientId';
                inputPatientId.value = patientId;

                form.appendChild(inputPatientId);
                document.body.appendChild(form);
                form.submit();
            });
        }

        window.addEventListener('click', function(e) {
            if (e.target === modal) { modal.style.display = 'none'; }
        });
    </script>
}