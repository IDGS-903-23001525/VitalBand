@model VitalBand.Models.ResetPasswordViewModel
@{
    ViewData["Title"] = "Restablecer Contraseña - VitalBand";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
            *, *::before, *::after {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            :root {
                /* Paleta Ajustada: Esmeralda y Teals Médicos Profundos */
                --teal-700: #0f766e;
                --teal-600: #0d9488;
                --teal-500: #14b8a6;
                --teal-400: #2dd4bf;
                --teal-100: #ccfbf1;
                --em-600: #059669;
                --em-500: #10b981;
                --em-400: #34d399;
                --em-100: #d1fae5;
                --gray-900: #0f172a;
                --gray-700: #334155;
                --gray-600: #475569;
                --gray-400: #94a3b8;
                --gray-200: #e2e8f0;
                --gray-100: #f1f5f9;
                --red-600: #dc2626;
                --red-50: #fef2f2;
                --white: #ffffff;
            }

            body {
                font-family: 'Inter', sans-serif;
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                color: var(--gray-900);
                background: linear-gradient(145deg, #09333f 0%, #0d4856 60%, #115e59 100%);
                background-attachment: fixed;
                position: relative;
                overflow: hidden;
            }

                body::before {
                    content: '';
                    position: fixed;
                    top: -15%;
                    left: -10%;
                    width: 550px;
                    height: 550px;
                    background: radial-gradient(circle, rgba(20,184,166,0.15) 0%, transparent 65%);
                    border-radius: 50%;
                    pointer-events: none;
                }

                body::after {
                    content: '';
                    position: fixed;
                    bottom: -15%;
                    right: -8%;
                    width: 480px;
                    height: 480px;
                    background: radial-gradient(circle, rgba(13,148,136,0.12) 0%, transparent 65%);
                    border-radius: 50%;
                    pointer-events: none;
                }

            .login-wrapper {
                display: flex;
                width: 100%;
                max-width: 1040px;
                min-height: 620px;
                border-radius: 24px;
                overflow: hidden;
                margin: 2rem;
                border: 1px solid rgba(255,255,255,0.12);
                box-shadow: 0 32px 80px rgba(4,28,35,0.4), 0 0 0 1px rgba(255,255,255,0.05);
                position: relative;
                z-index: 1;
            }

            .login-brand {
                width: 42%;
                background: rgba(255,255,255,0.04);
                backdrop-filter: blur(24px);
                -webkit-backdrop-filter: blur(24px);
                padding: 3rem 2rem;
                display: flex;
                flex-direction: column;
                justify-content: space-between;
                align-items: center;
                border-right: 1px solid rgba(255,255,255,0.08);
                text-align: center;
            }

            .brand-logo-container {
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                gap: 14px;
                width: 100%;
                min-height: 190px;
                margin-bottom: 1.5rem;
            }

            .logo-icon-img {
                width: 115px;
                height: 115px;
                object-fit: contain;
                display: block;
            }

            .logo-text-img {
                width: 225px;
                height: auto;
                object-fit: contain;
                display: block;
            }

            .brand-copy {
                width: 100%;
                max-width: 290px;
                margin: 0 auto;
                flex: 1;
                display: flex;
                flex-direction: column;
                justify-content: center;
            }

            .brand-em-line {
                width: 45px;
                height: 3px;
                background: linear-gradient(90deg, var(--teal-400), var(--em-400));
                border-radius: 2px;
                margin: 0 auto 1rem auto;
            }

            .brand-copy h2 {
                font-size: 1.6rem;
                font-weight: 600;
                color: var(--white);
                line-height: 1.35;
                margin-bottom: 0.65rem;
            }

            .brand-copy p {
                font-size: 0.85rem;
                color: rgba(255,255,255,0.65);
                line-height: 1.6;
            }

            .brand-stats {
                display: flex;
                gap: 1.5rem;
                margin-top: 1.5rem;
                justify-content: center;
                width: 100%;
            }

            .brand-stat {
                border-top: 1px solid rgba(255,255,255,0.12);
                padding-top: 0.75rem;
                flex: 1;
                max-width: 110px;
            }

                .brand-stat strong {
                    display: block;
                    font-size: 1.2rem;
                    font-weight: 700;
                    color: var(--white);
                }

                .brand-stat span {
                    display: block;
                    font-size: 0.72rem;
                    color: rgba(255,255,255,0.5);
                    margin-top: 2px;
                }

            .login-form-panel {
                flex: 1;
                padding: 4rem 4rem;
                display: flex;
                flex-direction: column;
                justify-content: center;
                background: #fafbfc;
            }

            .form-header {
                margin-bottom: 2.2rem;
            }

                .form-header h1 {
                    font-size: 1.65rem;
                    font-weight: 700;
                    color: var(--gray-900);
                    margin-bottom: 0.4rem;
                    text-transform: uppercase; /* El Bienvenido de vuelta pasó a mayúsculas, este también */
                    letter-spacing: 0.5px;
                }

                .form-header p {
                    font-size: 0.92rem;
                    color: var(--gray-700);
                }

            .form-group {
                margin-bottom: 1.4rem;
            }

                .form-group label {
                    display: block;
                    font-size: 0.75rem;
                    font-weight: 700;
                    color: var(--gray-700);
                    margin-bottom: 0.5rem;
                    text-transform: uppercase;
                    letter-spacing: 0.9px;
                }

                .form-group input {
                    width: 100%;
                    padding: 0.95rem 1.1rem;
                    font-family: 'Inter', sans-serif;
                    font-size: 0.95rem;
                    color: var(--gray-900);
                    background: var(--white);
                    border: 1.5px solid #cbd5e1; /* El borde limpio de los inputs del login */
                    border-radius: 12px;
                    outline: none;
                    transition: border-color 0.2s, box-shadow 0.2s;
                    line-height: 1.4;
                    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
                }

                    .form-group input:focus {
                        border-color: var(--teal-600);
                        box-shadow: 0 0 0 4px rgba(13,148,136,0.12), 0 1px 2px rgba(0, 0, 0, 0.05);
                    }

            .btn-submit {
                width: 100%;
                padding: 0.95rem;
                background: linear-gradient(135deg, var(--teal-700), var(--teal-600));
                color: var(--white);
                font-family: 'Inter', sans-serif;
                font-size: 0.95rem;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.8px;
                border: none;
                border-radius: 12px;
                cursor: pointer;
                transition: opacity 0.15s, box-shadow 0.15s;
                box-shadow: 0 4px 18px rgba(13,148,136,0.3);
            }

                .btn-submit:hover {
                    opacity: 0.95;
                    box-shadow: 0 6px 24px rgba(13,148,136,0.42);
                }

                .btn-submit:active {
                    transform: scale(0.985);
                }

            .success-summary {
                background: var(--em-100);
                border: 1.5px solid var(--em-400);
                border-radius: 16px;
                padding: 2rem;
                font-size: 0.95rem;
                color: var(--em-600);
                line-height: 1.6;
                text-align: center;
                box-shadow: 0 4px 12px rgba(16,185,129,0.1);
            }

                .success-summary h2 {
                    font-size: 1.4rem;
                    font-weight: 700;
                    margin-bottom: 0.6rem;
                    color: var(--em-600);
                    text-transform: uppercase;
                    letter-spacing: 0.5px;
                }

            .countdown-badge {
                display: inline-block;
                margin-top: 1.25rem;
                padding: 0.5rem 1.25rem;
                background: rgba(16,185,129,0.15);
                border-radius: 20px;
                font-weight: 600;
                font-size: 0.88rem;
            }

            .validation-summary {
                background: var(--red-50);
                border: 1.5px solid #fca5a5;
                border-radius: 12px;
                padding: 0.8rem 1.1rem;
                margin-bottom: 1.4rem;
                font-size: 0.88rem;
                color: var(--red-600);
            }

                .validation-summary ul {
                    list-style-type: none;
                }

            .divider {
                border: none;
                border-top: 1px solid #e2e8f0;
                margin: 1.8rem 0;
            }

            .form-footer {
                text-align: center;
                font-size: 0.88rem;
                color: var(--gray-700);
            }

                .form-footer a {
                    color: var(--teal-600);
                    text-decoration: none;
                    font-weight: 600;
                    transition: color 0.15s;
                }

                    .form-footer a:hover {
                        color: var(--teal-700);
                        text-decoration: underline;
                    }

            @@media (max-width: 768px) {
                .login-brand {
                    display: none;
                }

                .login-wrapper {
                    margin: 1rem;
                    border-radius: 18px;
                    max-width: 480px;
                }

                .login-form-panel {
                    padding: 3rem 2rem;
                }
            }
    </style>
</head>
<body>
    <div class="login-wrapper">
        <div class="login-brand">
            <div class="brand-logo-container">
                <img src="~/img/logoVitalBand.png?v=1.8" alt="Logo VitalBand" class="logo-icon-img" />
                <img src="~/img/letrasVitalBand.png?v=1.8" alt="VitalBand" class="logo-text-img" />
            </div>

            <div class="brand-copy">
                <div class="brand-em-line"></div>
                <h2>Monitoreo cardíaco inteligente</h2>
                <p>Accede a tus métricas de salud en tiempo real, historial de incidentes y reportes personalizados.</p>
                <div class="brand-stats">
                    <div class="brand-stat">
                        <strong>24/7</strong>
                        <span>Monitoreo activo</span>
                    </div>
                    <div class="brand-stat">
                        <strong>100%</strong>
                        <span>Datos seguros</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="login-form-panel">
            @if (ViewBag.Exito != null && (bool)ViewBag.Exito)
            {
                <div class="success-summary">
                    <h2>¡Contraseña Actualizada!</h2>
                    <p>Tu nueva clave ha sido registrada de forma segura en VitalBand.</p>
                    <div class="countdown-badge">
                        Redirigiendo al login en <span id="contador">5</span> segundos...
                    </div>
                </div>

                <script>
                                let segundos = 5;
                                const textoContador = document.getElementById('contador');

                                const cuentaRegresiva = setInterval(() => {
                                    segundos--;
                                    textoContador.textContent = segundos;

                                    if (segundos <= 0) {
                                        clearInterval(cuentaRegresiva);
                                        window.location.href = '@Url.Action("Login", "Account")';
                                    }
                                }, 1000);
                </script>
            }
            else
            {
                <div class="form-header">
                    <h1>Restablecer Contraseña</h1>
                    <p>Ingresa tu nueva clave de acceso y confírmala para guardar los cambios.</p>
                </div>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="validation-summary">
                        <div asp-validation-summary="All"></div>
                    </div>
                }

                <form asp-action="ResetPassword" asp-controller="Account" method="post">
                    @Html.AntiForgeryToken()

                    <input type="hidden" asp-for="Token" />
                    <input type="hidden" asp-for="Email" />

                    <div class="form-group">
                        <label asp-for="Password">Nueva Contraseña</label>
                        <input asp-for="Password" type="password" placeholder="••••••••" required autofocus />
                    </div>

                    <div class="form-group">
                        <label asp-for="ConfirmPassword">Confirmar Contraseña</label>
                        <input asp-for="ConfirmPassword" type="password" placeholder="••••••••" required />
                    </div>

                    <button type="submit" class="btn-submit">Actualizar contraseña</button>
                </form>

                <hr class="divider" />
                <p class="form-footer">¿Recordaste tu contraseña? <a asp-action="Login" asp-controller="Account">Iniciar Sesión</a></p>
            }
        </div>
    </div>
</body>
</html>