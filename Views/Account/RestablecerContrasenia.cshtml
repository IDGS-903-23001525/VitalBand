@model VitalBand.Models.ResetPasswordViewModel
@{
    ViewData["Title"] = "Restablecer Contraseña - VitalBand";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
            *, *::before, *::after {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            :root {
                --teal-700: #0a6775;
                --teal-600: #0891b2;
                --teal-500: #06b6d4;
                --teal-400: #22d3ee;
                --teal-100: #cffafe;
                --em-600: #059669;
                --em-500: #10b981;
                --em-400: #34d399;
                --em-100: #d1fae5;
                --gray-900: #0f172a;
                --gray-700: #334155;
                --gray-600: #475569;
                --gray-400: #94a3b8;
                --gray-200: #e2e8f0;
                --gray-100: #f1f5f9;
                --red-600: #dc2626;
                --red-50: #fef2f2;
                --white: #ffffff;
            }

            body {
                font-family: 'Inter', sans-serif;
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                color: var(--gray-900);
                background: linear-gradient(145deg, #0d3d40 0%, #065f46 40%, #0891b2 75%, #22d3ee 100%);
                background-attachment: fixed;
                position: relative;
                overflow: hidden;
            }

                body::before {
                    content: '';
                    position: fixed;
                    top: -15%;
                    left: -10%;
                    width: 550px;
                    height: 550px;
                    background: radial-gradient(circle, rgba(52,211,153,0.2) 0%, transparent 65%);
                    border-radius: 50%;
                    pointer-events: none;
                }

                body::after {
                    content: '';
                    position: fixed;
                    bottom: -15%;
                    right: -8%;
                    width: 480px;
                    height: 480px;
                    background: radial-gradient(circle, rgba(34,211,238,0.18) 0%, transparent 65%);
                    border-radius: 50%;
                    pointer-events: none;
                }

            .login-wrapper {
                display: flex;
                width: 100%;
                max-width: 880px;
                min-height: 530px;
                border-radius: 24px;
                overflow: hidden;
                margin: 2rem;
                border: 1px solid rgba(255,255,255,0.18);
                box-shadow: 0 32px 80px rgba(0,0,0,0.28), 0 0 0 1px rgba(255,255,255,0.08);
                position: relative;
                z-index: 1;
            }

            .login-brand {
                width: 42%;
                background: rgba(255,255,255,0.07);
                backdrop-filter: blur(24px);
                -webkit-backdrop-filter: blur(24px);
                padding: 3rem;
                display: flex;
                flex-direction: column;
                justify-content: space-between;
                border-right: 1px solid rgba(255,255,255,0.12);
            }

            .brand-logo {
                display: flex;
                align-items: center;
                gap: 10px;
            }

            .brand-logo-icon {
                width: 38px;
                height: 38px;
                background: rgba(255,255,255,0.12);
                border-radius: 11px;
                display: flex;
                align-items: center;
                justify-content: center;
                border: 1px solid rgba(255,255,255,0.2);
            }

                .brand-logo-icon svg {
                    width: 20px;
                    height: 20px;
                }

            .brand-logo-text {
                font-size: 1.1rem;
                font-weight: 700;
                color: var(--white);
                letter-spacing: -0.3px;
            }

            .brand-copy {
                margin-top: auto;
            }

                .brand-copy h2 {
                    font-size: 1.45rem;
                    font-weight: 600;
                    color: var(--white);
                    line-height: 1.4;
                    margin-bottom: 0.75rem;
                }

                .brand-copy p {
                    font-size: 0.85rem;
                    color: rgba(255,255,255,0.62);
                    line-height: 1.7;
                }

            .brand-em-line {
                width: 40px;
                height: 3px;
                background: linear-gradient(90deg, var(--em-400), var(--teal-400));
                border-radius: 2px;
                margin-bottom: 1.25rem;
            }

            .login-form-panel {
                flex: 1;
                padding: 3rem 2.5rem;
                display: flex;
                flex-direction: column;
                justify-content: center;
                background: rgba(255,255,255,0.92);
                backdrop-filter: blur(24px) saturate(160%);
                -webkit-backdrop-filter: blur(24px) saturate(160%);
            }

            .form-header {
                margin-bottom: 2rem;
            }

                .form-header h1 {
                    font-size: 1.45rem;
                    font-weight: 700;
                    color: var(--gray-900);
                    margin-bottom: 0.35rem;
                }

                .form-header p {
                    font-size: 0.85rem;
                    color: var(--gray-600);
                    line-height: 1.5;
                }

            .form-group {
                margin-bottom: 1.5rem;
            }

                .form-group label {
                    display: block;
                    font-size: 0.72rem;
                    font-weight: 600;
                    color: var(--gray-600);
                    margin-bottom: 0.4rem;
                    text-transform: uppercase;
                    letter-spacing: 0.7px;
                }

                .form-group input {
                    width: 100%;
                    padding: 0.7rem 1rem;
                    font-family: 'Inter', sans-serif;
                    font-size: 0.9rem;
                    color: var(--gray-900);
                    background: rgba(248,250,252,0.9);
                    border: 1.5px solid var(--gray-200);
                    border-radius: 10px;
                    outline: none;
                    transition: border-color 0.15s, box-shadow 0.15s;
                }

                    .form-group input:focus {
                        border-color: var(--teal-500);
                        box-shadow: 0 0 0 3px rgba(6,182,212,0.14);
                        background: var(--white);
                    }

            .btn-submit {
                width: 100%;
                padding: 0.78rem;
                background: linear-gradient(135deg, var(--teal-700), var(--teal-500));
                color: var(--white);
                font-family: 'Inter', sans-serif;
                font-size: 0.9rem;
                font-weight: 600;
                border: none;
                border-radius: 10px;
                cursor: pointer;
                transition: opacity 0.15s, transform 0.1s, box-shadow 0.15s;
                box-shadow: 0 4px 16px rgba(6,182,212,0.35);
            }

                .btn-submit:hover {
                    opacity: 0.91;
                    box-shadow: 0 6px 22px rgba(6,182,212,0.45);
                }

                .btn-submit:active {
                    transform: scale(0.99);
                }

            .success-summary {
                background: var(--em-100);
                border: 1.5px solid var(--em-400);
                border-radius: 12px;
                padding: 1.5rem;
                font-size: 0.95rem;
                color: var(--em-600);
                line-height: 1.6;
                text-align: center;
                box-shadow: 0 4px 12px rgba(16,185,129,0.1);
            }

                .success-summary h2 {
                    font-size: 1.3rem;
                    font-weight: 700;
                    margin-bottom: 0.5rem;
                    color: var(--em-600);
                }

            .countdown-badge {
                display: inline-block;
                margin-top: 1rem;
                padding: 0.4rem 1rem;
                background: rgba(16,185,129,0.15);
                border-radius: 20px;
                font-weight: 600;
                font-size: 0.85rem;
            }

            .validation-summary {
                background: var(--red-50);
                border: 1.5px solid #fca5a5;
                border-radius: 10px;
                padding: 0.75rem 1rem;
                margin-bottom: 1.25rem;
                font-size: 0.85rem;
                color: var(--red-600);
            }

                .validation-summary ul {
                    list-style-type: none;
                }

            .divider {
                border: none;
                border-top: 1px solid var(--gray-200);
                margin: 1.5rem 0;
            }

            .form-footer {
                text-align: center;
                font-size: 0.8rem;
                color: var(--gray-400);
            }

                .form-footer a {
                    color: var(--teal-600);
                    text-decoration: none;
                    font-weight: 500;
                }
    </style>
</head>
<body>
    <div class="login-wrapper">
        <div class="login-brand">
            <div class="brand-logo">
                <div class="brand-logo-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 12 L7 7 L11 15 L15 5 L19 12" />
                    </svg>
                </div>
                <span class="brand-logo-text">VitalBand</span>
            </div>

            <div class="brand-copy">
                <div class="brand-em-line"></div>
                <h2>Seguridad Total</h2>
                <p>Establece tus nuevas credenciales de acceso para seguir monitoreando la salud de tus pacientes de forma segura.</p>
            </div>
        </div>

        <div class="login-form-panel">

            @if (ViewBag.Exito != null && (bool)ViewBag.Exito)
            {
                <div class="success-summary">
                    <h2>¡Contraseña Actualizada!</h2>
                    <p>Tu nueva clave ha sido registrada de forma segura en VitalBand.</p>
                    <div class="countdown-badge">
                        Redirigiendo al login en <span id="contador">5</span> segundos...
                    </div>
                </div>

                <script>
                                let segundos = 5;
                                const textoContador = document.getElementById('contador');

                                const cuentaRegresiva = setInterval(() => {
                                    segundos--;
                                    textoContador.textContent = segundos;

                                    if (segundos <= 0) {
                                        clearInterval(cuentaRegresiva);
                                        window.location.href = '@Url.Action("Login", "Account")';
                                    }
                                }, 1000);
                </script>
            }
            else
            {
                <div class="form-header">
                    <h1>Restablecer Contraseña</h1>
                    <p>Ingresa tu nueva clave de acceso y confírmala para guardar los cambios.</p>
                </div>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="validation-summary">
                        <div asp-validation-summary="All"></div>
                    </div>
                }

                <form asp-action="ResetPassword" asp-controller="Account" method="post">
                    @Html.AntiForgeryToken()

                    <input type="hidden" asp-for="Token" />
                    <input type="hidden" asp-for="Email" />

                    <div class="form-group">
                        <label asp-for="Password">Nueva Contraseña</label>
                        <input asp-for="Password" type="password" placeholder="••••••••" required autofocus />
                    </div>

                    <div class="form-group">
                        <label asp-for="ConfirmPassword">Confirmar Contraseña</label>
                        <input asp-for="ConfirmPassword" type="password" placeholder="••••••••" required />
                    </div>

                    <button type="submit" class="btn-submit">Actualizar contraseña</button>
                </form>

                <hr class="divider" />
                <p class="form-footer">¿Recordaste tu contraseña? <a asp-action="Login" asp-controller="Account">Iniciar Sesión</a></p>
            }
        </div>
    </div>
</body>
</html>