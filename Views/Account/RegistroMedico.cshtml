@* El modelo se mantiene tal cual lo tengas definido en tu backend *@
@{
    ViewData["Title"] = "Registro de Médicos - VitalBand";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
            *, *::before, *::after {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            :root {
                /* Paleta Ajustada: Esmeralda y Teals Médicos Profundos */
                --teal-700: #0f766e;
                --teal-600: #0d9488;
                --teal-500: #14b8a6;
                --teal-400: #2dd4bf;
                --teal-100: #ccfbf1;
                --em-600: #059669;
                --em-500: #10b981;
                --em-400: #34d399;
                --em-100: #d1fae5;
                --gray-900: #0f172a;
                --gray-700: #334155;
                --gray-600: #475569;
                --gray-400: #94a3b8;
                --gray-200: #e2e8f0;
                --gray-100: #f1f5f9;
                --red-600: #dc2626;
                --red-50: #fef2f2;
                --white: #ffffff;
            }

            body {
                font-family: 'Inter', sans-serif;
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                color: var(--gray-900);
                background: linear-gradient(145deg, #09333f 0%, #0d4856 60%, #115e59 100%);
                background-attachment: fixed;
                position: relative;
                overflow: hidden;
            }

                body::before {
                    content: '';
                    position: fixed;
                    top: -15%;
                    left: -10%;
                    width: 550px;
                    height: 550px;
                    background: radial-gradient(circle, rgba(20,184,166,0.15) 0%, transparent 65%);
                    border-radius: 50%;
                    pointer-events: none;
                }

                body::after {
                    content: '';
                    position: fixed;
                    bottom: -15%;
                    right: -8%;
                    width: 480px;
                    height: 480px;
                    background: radial-gradient(circle, rgba(13,148,136,0.12) 0%, transparent 65%);
                    border-radius: 50%;
                    pointer-events: none;
                }

            .login-wrapper {
                display: flex;
                width: 100%;
                max-width: 1040px;
                min-height: 640px;
                border-radius: 24px;
                overflow: hidden;
                margin: 2rem;
                border: 1px solid rgba(255,255,255,0.12);
                box-shadow: 0 32px 80px rgba(4,28,35,0.4), 0 0 0 1px rgba(255,255,255,0.05);
                position: relative;
                z-index: 1;
            }

            .login-brand {
                width: 42%;
                background: rgba(255,255,255,0.04);
                backdrop-filter: blur(24px);
                -webkit-backdrop-filter: blur(24px);
                padding: 3.5rem 2rem;
                display: flex;
                flex-direction: column;
                justify-content: space-between;
                align-items: center;
                border-right: 1px solid rgba(255,255,255,0.08);
                text-align: center;
            }

            .brand-logo-container {
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                gap: 14px;
                width: 100%;
                min-height: 190px;
                margin-bottom: 1.5rem;
            }

            .logo-icon-img {
                width: 115px;
                height: 115px;
                object-fit: contain;
                display: block;
            }

            .logo-text-img {
                width: 225px;
                height: auto;
                object-fit: contain;
                display: block;
            }

            .brand-copy {
                width: 100%;
                max-width: 290px;
                margin: 0 auto;
                flex: 1;
                display: flex;
                flex-direction: column;
                justify-content: center;
            }

            .brand-em-line {
                width: 45px;
                height: 3px;
                background: linear-gradient(90deg, var(--teal-400), var(--em-400));
                border-radius: 2px;
                margin: 0 auto 1rem auto;
            }

            .brand-copy h2 {
                font-size: 1.6rem;
                font-weight: 600;
                color: var(--white);
                line-height: 1.35;
                margin-bottom: 0.65rem;
            }

            .brand-copy p {
                font-size: 0.85rem;
                color: rgba(255,255,255,0.65);
                line-height: 1.6;
            }

            .login-form-panel {
                flex: 1;
                padding: 3rem 4rem;
                display: flex;
                flex-direction: column;
                justify-content: center;
                background: #fafbfc;
                position: relative;
            }

            .form-header {
                margin-bottom: 1.5rem;
            }

                .form-header h1 {
                    font-size: 1.65rem;
                    font-weight: 700;
                    color: var(--gray-900);
                    margin-bottom: 0.4rem;
                    text-transform: uppercase;
                    letter-spacing: 0.5px;
                }

                .form-header p {
                    font-size: 0.92rem;
                    color: var(--gray-700);
                }

            .form-group {
                margin-bottom: 1.1rem;
            }

                .form-group label {
                    display: block;
                    font-size: 0.75rem;
                    font-weight: 700;
                    color: var(--gray-700);
                    margin-bottom: 0.5rem;
                    text-transform: uppercase;
                    letter-spacing: 0.9px;
                }

                /* ESTILOS DE ENTRADAS COMPARTIDOS CON EL SELECT */
                .form-group input,
                .form-group select {
                    width: 100%;
                    padding: 0.85rem 1.1rem;
                    font-family: 'Inter', sans-serif;
                    font-size: 0.95rem;
                    color: var(--gray-900);
                    background: var(--white);
                    border: 1.5px solid #cbd5e1;
                    border-radius: 12px;
                    outline: none;
                    transition: border-color 0.2s, box-shadow 0.2s;
                    line-height: 1.4;
                    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
                }

                    .form-group input:focus,
                    .form-group select:focus {
                        border-color: var(--teal-600);
                        box-shadow: 0 0 0 4px rgba(13,148,136,0.12), 0 1px 2px rgba(0, 0, 0, 0.05);
                    }

                /* ESTILIZACIÓN DEL SELECT DE ESPECIALIDADES */
                .form-group select {
                    appearance: none;
                    -webkit-appearance: none;
                    -moz-appearance: none;
                    /* Ícono estético de flecha médica/limpia */
                    background-image: url("data:image/svg+xml;charset=utf-8,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23475569' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'%3E<polyline points='6 9 12 15 18 9'></polyline></svg>");
                    background-repeat: no-repeat;
                    background-position: right 1.1rem center;
                    background-size: 16px;
                    cursor: pointer;
                }

                .form-group input::placeholder {
                    color: var(--gray-400);
                    font-size: 0.88rem;
                }

            .btn-register {
                width: 100%;
                padding: 0.95rem;
                background: linear-gradient(135deg, var(--teal-700), var(--teal-600));
                color: var(--white);
                font-family: 'Inter', sans-serif;
                font-size: 0.95rem;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.8px;
                border: none;
                border-radius: 12px;
                cursor: pointer;
                transition: opacity 0.15s, box-shadow 0.15s;
                box-shadow: 0 4px 18px rgba(13,148,136,0.3);
                margin-top: 0.5rem;
            }

                .btn-register:hover {
                    opacity: 0.95;
                    box-shadow: 0 6px 24px rgba(13,148,136,0.42);
                }

                .btn-register:active {
                    transform: scale(0.985);
                }

            .validation-summary-custom {
                background: var(--red-50);
                border: 1.5px solid #fca5a5;
                border-radius: 12px;
                padding: 0.8rem 1.1rem;
                margin-bottom: 1.4rem;
                font-size: 0.88rem;
                color: var(--red-600);
                text-align: left;
            }

            /* CARD DINÁMICA DE AYUDA */
            .support-card-overlay {
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background: rgba(15, 23, 42, 0.4);
                backdrop-filter: blur(8px);
                -webkit-backdrop-filter: blur(8px);
                display: flex;
                align-items: flex-end;
                z-index: 10;
                opacity: 0;
                pointer-events: none;
                transition: opacity 0.3s ease;
            }

                .support-card-overlay.active {
                    opacity: 1;
                    pointer-events: auto;
                }

            .support-card {
                width: 100%;
                background: var(--white);
                border-radius: 24px 24px 0 0;
                padding: 2.5rem 3rem;
                box-shadow: 0 -10px 40px rgba(0,0,0,0.15);
                transform: translateY(100%);
                transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
                position: relative;
            }

            .support-card-overlay.active .support-card {
                transform: translateY(0);
            }

            .close-card-btn {
                position: absolute;
                top: 1.25rem;
                right: 1.5rem;
                background: rgba(15,23,42,0.05);
                border: none;
                width: 2rem;
                height: 2rem;
                border-radius: 50%;
                cursor: pointer;
                display: flex;
                align-items: center;
                justify-content: center;
                color: var(--gray-700);
                transition: background 0.15s;
            }

                .close-card-btn:hover {
                    background: rgba(15,23,42,0.1);
                }

            .support-title {
                font-size: 1.2rem;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                margin-bottom: 1.5rem;
                color: var(--gray-900);
                border-bottom: 2px solid var(--gray-100);
                padding-bottom: 0.5rem;
            }

            .support-option-item {
                display: flex;
                align-items: center;
                gap: 16px;
                padding: 1rem;
                background: #f8fafc;
                border: 1px solid var(--gray-200);
                border-radius: 12px;
                text-decoration: none;
                color: var(--gray-900);
                font-weight: 600;
                font-size: 0.95rem;
                margin-bottom: 0.85rem;
                transition: transform 0.15s, border-color 0.15s, background 0.15s;
            }

                .support-option-item:hover {
                    transform: translateY(-2px);
                    border-color: var(--teal-500);
                    background: var(--white);
                }

                .support-option-item span.icon {
                    font-size: 1.3rem;
                    background: var(--white);
                    width: 2.5rem;
                    height: 2.5rem;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    border-radius: 10px;
                    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
                }

            .form-footer {
                text-align: center;
                font-size: 0.88rem;
                color: var(--gray-700);
                margin-top: 1.5rem;
            }

                .form-footer a {
                    color: var(--teal-600);
                    text-decoration: none;
                    font-weight: 700;
                    cursor: pointer;
                }

                    .form-footer a:hover {
                        color: var(--teal-700);
                        text-decoration: underline;
                    }

            @@media (max-width: 768px) {
                .login-brand {
                    display: none;
                }

                .login-wrapper {
                    margin: 1rem;
                    border-radius: 18px;
                    max-width: 480px;
                }

                .login-form-panel {
                    padding: 3rem 2rem;
                }

                .support-card {
                    padding: 2rem 1.5rem;
                }
            }
    </style>
</head>
<body>
    <div class="login-wrapper">
        <!-- Panel Izquierdo Coincidente con Logos Grandes -->
        <div class="login-brand">
            <div class="brand-logo-container">
                <img src="~/img/logoVitalBand.png?v=1.7" alt="Logo VitalBand" class="logo-icon-img" />
                <img src="~/img/letrasVitalBand.png?v=1.7" alt="VitalBand" class="logo-text-img" />
            </div>

            <div class="brand-copy">
                <div class="brand-em-line"></div>
                <h2>Plataforma Médica</h2>
                <p>Gestiona expedientes clínicos, monitorea alertas críticas de tus pacientes asignados y personaliza rangos de riesgo en tiempo real.</p>
            </div>
        </div>

        <!-- Panel de Formulario Estilizado -->
        <div class="login-form-panel">
            <div class="form-header">
                <h1>Únete a VitalBand</h1>
                <p>Crea tu cuenta de especialista médico</p>
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="validation-summary-custom">
                    @ViewBag.Error
                </div>
            }

            <form asp-action="RegistroMedico" method="post">
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <label for="nombre">Nombre Completo</label>
                    <input type="text" id="nombre" name="nombre" placeholder="Dr. o Dra. Ejemplo" required />
                </div>

                <div class="form-group">
                    <label for="specialty">Especialidad Médica</label>
                    @* Campo reemplazado por un Select elegante *@
                    <select id="specialty" name="specialty" required>
                        <option value="" disabled selected hidden>Selecciona tu especialidad</option>
                        <option value="Cardiología">Cardiología</option>
                        <option value="Medicina General">Medicina General</option>
                        <option value="Urgencias Médicas">Urgencias Médicas</option>
                        <option value="Medicina Interna">Medicina Interna</option>
                        <option value="Pediatría">Pediatría</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="cedula">Cédula Profesional</label>
                    <input type="text" id="cedula" name="cedula" placeholder="Tu número de cédula oficial" required />
                </div>

                <div class="form-group">
                    <label for="email">Correo electrónico</label>
                    <input type="email" id="email" name="email" placeholder="doctor@vitalband.com" required />
                </div>

                <div class="form-group">
                    <label for="password">Contraseña</label>
                    <input type="password" id="password" name="password" placeholder="••••••••" required />
                </div>

                <button type="submit" class="btn-register">Registrarme como Médico</button>
            </form>

            <p class="form-footer">¿Necesitas ayuda? <a id="openSupportLink">Más información aquí</a></p>

            <!-- CARD DINÁMICA DE ACCESOS Y SOPORTE -->
            <div class="support-card-overlay" id="supportOverlay">
                <div class="support-card">
                    <button type="button" class="close-card-btn" id="closeSupportBtn" aria-label="Cerrar">✕</button>
                    <h2 class="support-title">Centro de ayuda y accesos</h2>

                    <a asp-action="Login" asp-controller="Account" class="support-option-item">
                        <span class="icon">🔐</span>
                        <div>¿Ya tienes cuenta? Inicia sesión aquí</div>
                    </a>

                    <a href="#" class="support-option-item" style="margin-bottom: 0;">
                        <span class="icon">🛠️</span>
                        <div>Contactar con soporte técnico directo</div>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <script>
            document.addEventListener('DOMContentLoaded', function() {
                // Lógica para abrir y cerrar la Card Dinámica
                var overlay = document.getElementById('supportOverlay');
                var openBtn = document.getElementById('openSupportLink');
                var closeBtn = document.getElementById('closeSupportBtn');

                if(openBtn && overlay && closeBtn) {
                    openBtn.addEventListener('click', function() {
                        overlay.classList.add('active');
                    });

                    closeBtn.addEventListener('click', function() {
                        overlay.classList.remove('active');
                    });

                    overlay.addEventListener('click', function(e) {
                        if (e.target === overlay) {
                            overlay.classList.remove('active');
                        }
                    });
                }
            });
    </script>
</body>
</html>