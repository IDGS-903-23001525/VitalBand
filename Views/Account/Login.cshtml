@model VitalBand.Models.Login
@{
    ViewData["Title"] = "Iniciar Sesión - VitalBand";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
            *, *::before, *::after {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            :root {
                --teal-700: #0a6775;
                --teal-600: #0891b2;
                --teal-500: #06b6d4;
                --teal-400: #22d3ee;
                --teal-100: #cffafe;
                --em-600: #059669;
                --em-500: #10b981;
                --em-400: #34d399;
                --em-100: #d1fae5;
                --gray-900: #0f172a;
                --gray-700: #334155;
                --gray-600: #475569;
                --gray-400: #94a3b8;
                --gray-200: #e2e8f0;
                --gray-100: #f1f5f9;
                --red-600: #dc2626;
                --red-50: #fef2f2;
                --white: #ffffff;
            }

            body {
                font-family: 'Inter', sans-serif;
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                color: var(--gray-900);
                background: linear-gradient(145deg, #0d3d40 0%, #065f46 40%, #0891b2 75%, #22d3ee 100%);
                background-attachment: fixed;
                position: relative;
                overflow: hidden;
            }

                body::before {
                    content: '';
                    position: fixed;
                    top: -15%;
                    left: -10%;
                    width: 550px;
                    height: 550px;
                    background: radial-gradient(circle, rgba(52,211,153,0.2) 0%, transparent 65%);
                    border-radius: 50%;
                    pointer-events: none;
                }

                body::after {
                    content: '';
                    position: fixed;
                    bottom: -15%;
                    right: -8%;
                    width: 480px;
                    height: 480px;
                    background: radial-gradient(circle, rgba(34,211,238,0.18) 0%, transparent 65%);
                    border-radius: 50%;
                    pointer-events: none;
                }

            .login-wrapper {
                display: flex;
                width: 100%;
                max-width: 1040px;
                min-height: 560px;
                border-radius: 24px;
                overflow: hidden;
                margin: 2rem;
                border: 1px solid rgba(255,255,255,0.18);
                box-shadow: 0 32px 80px rgba(0,0,0,0.28), 0 0 0 1px rgba(255,255,255,0.08);
                position: relative;
                z-index: 1;
            }

            .login-brand {
                width: 42%;
                background: rgba(255,255,255,0.07);
                backdrop-filter: blur(24px);
                -webkit-backdrop-filter: blur(24px);
                padding: 3.5rem 2.5rem;
                display: flex;
                flex-direction: column;
                justify-content: center;
                align-items: center;
                border-right: 1px solid rgba(255,255,255,0.12);
                text-align: center;
            }

            .brand-logo {
                display: flex;
                flex-direction: column;
                align-items: center;
                gap: 18px;
                margin-bottom: 1.75rem;
            }

            .brand-logo-icon {
                width: 72px;
                height: 72px;
                background: rgba(255,255,255,0.14);
                border-radius: 18px;
                display: flex;
                align-items: center;
                justify-content: center;
                border: 1px solid rgba(255,255,255,0.18);
            }

                .brand-logo-icon svg {
                    width: 36px;
                    height: 36px;
                }

            .brand-logo-text {
                font-size: 1.8rem;
                font-weight: 800;
                color: var(--white);
                letter-spacing: -0.3px;
                line-height: 1.05;
            }

            .brand-copy {
                width: 100%;
                max-width: 280px;
                margin: 0 auto;
            }

                .brand-copy h2 {
                    font-size: 1.75rem;
                    font-weight: 600;
                    color: var(--white);
                    line-height: 1.3;
                    margin-bottom: 0.75rem;
                }

                .brand-copy p {
                    font-size: 0.85rem;
                    color: rgba(255,255,255,0.62);
                    line-height: 1.7;
                }

            .brand-stats {
                display: flex;
                gap: 1.5rem;
                margin-top: 2rem;
            }

            .brand-stat {
                border-top: 1px solid rgba(255,255,255,0.15);
                padding-top: 0.75rem;
            }

                .brand-stat strong {
                    display: block;
                    font-size: 1.2rem;
                    font-weight: 700;
                    color: var(--white);
                }

                .brand-stat span {
                    font-size: 0.72rem;
                    color: rgba(255,255,255,0.55);
                }

            .brand-em-line {
                width: 40px;
                height: 3px;
                background: linear-gradient(90deg, var(--em-400), var(--teal-400));
                border-radius: 2px;
                margin-bottom: 1.25rem;
            }

            .login-form-panel {
                flex: 1;
                padding: 3.4rem 3rem;
                display: flex;
                flex-direction: column;
                justify-content: center;
                background: rgba(255,255,255,0.94);
                backdrop-filter: blur(24px) saturate(160%);
                -webkit-backdrop-filter: blur(24px) saturate(160%);
            }

            .form-header {
                margin-bottom: 2rem;
            }

                .form-header h1 {
                    font-size: 1.45rem;
                    font-weight: 700;
                    color: var(--gray-900);
                    margin-bottom: 0.35rem;
                }

                .form-header p {
                    font-size: 0.85rem;
                    color: var(--gray-400);
                }

            .form-group {
                margin-bottom: 1.2rem;
            }

                .form-group label {
                    display: block;
                    font-size: 0.72rem;
                    font-weight: 600;
                    color: var(--gray-600);
                    margin-bottom: 0.4rem;
                    text-transform: uppercase;
                    letter-spacing: 0.7px;
                }

                .form-group input {
                    width: 100%;
                    padding: 0.8rem 1rem;
                    font-family: 'Inter', sans-serif;
                    font-size: 0.95rem;
                    color: var(--gray-900);
                    background: rgba(248,250,252,0.9);
                    border: 1.5px solid var(--gray-200);
                    border-radius: 10px;
                    outline: none;
                    transition: border-color 0.15s, box-shadow 0.15s;
                    line-height: 1.4;
                }

                .password-wrapper {
                    position: relative;
                }

                .password-wrapper input {
                    padding-right: 4.2rem;
                    line-height: 1.4;
                }

                .password-toggle {
                    position: absolute;
                    right: 0.5rem;
                    bottom: 0.3rem;
                    width: 2.4rem;
                    height: 2.4rem;
                    display: inline-flex;
                    align-items: center;
                    justify-content: center;
                    cursor: pointer;
                    border-radius: 999px;
                    border: none;
                    background: rgba(15,23,42,0.06);
                    color: var(--gray-500);
                    line-height: 1;
                }

                .password-toggle:hover {
                    color: var(--teal-700);
                    background: rgba(6,182,212,0.12);
                }

                .checkbox-label input[type="checkbox"] {
                    width: 15px;
                    height: 15px;
                    accent-color: var(--teal-600);
                }

                .forgot-link {
                    font-size: 0.84rem;
                    color: var(--teal-600);
                    text-decoration: none;
                    font-weight: 500;
                }

                .forgot-link:hover {
                    text-decoration: underline;
                }

            .btn-login {
                width: 100%;
                margin-top:12px;
                padding: 0.78rem;
                background: linear-gradient(135deg, var(--teal-700), var(--teal-500));
                color: var(--white);
                font-family: 'Inter', sans-serif;
                font-size: 0.9rem;
                font-weight: 600;
                border: none;
                border-radius: 10px;
                cursor: pointer;
                transition: opacity 0.15s, transform 0.1s, box-shadow 0.15s;
                box-shadow: 0 4px 16px rgba(6,182,212,0.35);
            }

                .btn-login:hover {
                    opacity: 0.91;
                    box-shadow: 0 6px 22px rgba(6,182,212,0.45);
                }

                .btn-login:active {
                    transform: scale(0.99);
                }

            .validation-summary {
                background: var(--red-50);
                border: 1.5px solid #fca5a5;
                border-radius: 10px;
                padding: 0.75rem 1rem;
                margin-bottom: 1.25rem;
                font-size: 0.85rem;
                color: var(--red-600);
            }

                .validation-summary ul {
                    padding-left: 1rem;
                }

            .form-footer {
                margin-top: 1.5rem;
                text-align: center;
                font-size: 0.8rem;
                color: var(--gray-400);
            }

                .form-footer a {
                    color: var(--teal-600);
                    text-decoration: none;
                    font-weight: 500;
                }

            .divider {
                border: none;
                border-top: 1px solid var(--gray-200);
                margin: 1.5rem 0;
            }

            @@media (max-width: 640px) {
                .login-brand {
                    display: none;
                }

                .login-wrapper {
                    margin: 1rem;
                    border-radius: 18px;
                }
            }
    </style>
</head>
<body>
    <div class="login-wrapper">
        <div class="login-brand">
            <div class="brand-logo">
                <div class="brand-logo-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 12 L7 7 L11 15 L15 5 L19 12" />
                    </svg>
                </div>
                <span class="brand-logo-text">VitalBand</span>
            </div>

            <div class="brand-copy">
                <div class="brand-em-line"></div>
                <h2>Monitoreo cardíaco inteligente</h2>
                <p>Accede a tus métricas de salud en tiempo real, historial de incidentes y reportes personalizados.</p>
                <div class="brand-stats">
                    <div class="brand-stat">
                        <strong>24/7</strong>
                        <span>Monitoreo activo</span>
                    </div>
                    <div class="brand-stat">
                        <strong>100%</strong>
                        <span>Datos seguros</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="login-form-panel">
            @if (TempData["SuccessMessage"] != null)
            {
                <div style="background: #d1fae5; border: 1.5px solid #6ee7b7; border-radius: 10px; padding: 0.75rem 1rem; margin-bottom: 1.25rem; font-size: 0.85rem; color: #065f46; font-weight: 500; text-align: left;">
                    @TempData["SuccessMessage"]
                </div>
            }
            <div class="form-header">
                <h1>Bienvenido de vuelta</h1>
                <p>Ingresa tus credenciales para continuar</p>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="validation-summary">
                    <div asp-validation-summary="All"></div>
                </div>
            }

            <form asp-action="Login" asp-controller="Account" method="post">
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <label for="email">Correo electrónico</label>
                    <input type="email" id="email" name="Email" placeholder="usuario@vitalband.com" autocomplete="username" required />
                    <span asp-validation-for="Email" class="text-danger" style="font-size:0.8rem;color:var(--red-600);display:block;margin-top:4px;"></span>
                </div>

                <div class="form-group password-wrapper">
                    <label for="password">Contraseña</label>
                    <input type="password" id="password" name="Password" placeholder="••••••••" autocomplete="current-password" required />
                    <button type="button" id="togglePassword" class="password-toggle" aria-label="Mostrar contraseña">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M1 12s4.5-7 11-7 11 7 11 7-4.5 7-11 7-11-7-11-7z"></path>
                            <circle cx="12" cy="12" r="3"></circle>
                        </svg>
                    </button>
                    <span asp-validation-for="Password" class="text-danger" style="font-size:0.8rem;color:var(--red-600);display:block;margin-top:4px;"></span>
                </div>

                <div class="form-options">
                    <label class="checkbox-label">
                        <input type="checkbox" name="RememberMe" value="true" />
                        Mantener sesión iniciada
                    </label>
                    <a asp-action="ForgotPassword" asp-controller="Account" class="forgot-link">¿Olvidaste tu contraseña?</a>
                </div>

                <button type="submit" class="btn-login">Iniciar Sesión</button>
            </form>
            <script>
                document.addEventListener('DOMContentLoaded', function() {
                    var toggle = document.getElementById('togglePassword');
                    var password = document.getElementById('password');
                    if (!toggle || !password) return;

                    toggle.addEventListener('click', function() {
                        var type = password.getAttribute('type') === 'password' ? 'text' : 'password';
                        password.setAttribute('type', type);
                        toggle.innerHTML = type === 'password'
                            ? '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4.5-7 11-7 11 7 11 7-4.5 7-11 7-11-7-11-7z"></path><circle cx="12" cy="12" r="3"></circle></svg>'
                            : '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.94 10.94 0 0 1 12 19c-6.5 0-11-7-11-7a21.88 21.88 0 0 1 5.06-6.94"></path><path d="M1 1l22 22"></path></svg>';
                    });
                });
            </script>
            <div style="text-align: center; margin-top: 1.5rem; border-top: 1px solid rgba(6,182,212,0.15); padding-top: 1.5rem;">
                <p style="font-size: 0.85rem; color: #475569; margin-bottom: 0.5rem;">¿Eres especialista médico y no tienes cuenta?</p>
                <a asp-action="RegistroMedico" asp-controller="Account"
                   style="color: #0891b2; font-weight: 700; font-size: 0.9rem; text-decoration: none;">
                    🩺 Regístrate aquí
                </a>
            </div>
            <hr class="divider" />
            <p class="form-footer">¿Necesitas ayuda? <a href="#">Contactar soporte técnico</a></p>
        </div>
    </div>
</body>
</html>