@model VitalBand.Models.Login
@{
    ViewData["Title"] = "Iniciar Sesión - VitalBand";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
            *, *::before, *::after {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            :root {
                --teal-700: #0f766e;
                --teal-600: #0d9488;
                --teal-500: #14b8a6;
                --teal-400: #2dd4bf;
                --teal-100: #ccfbf1;
                --em-600: #059669;
                --em-500: #10b981;
                --em-400: #34d399;
                --em-100: #d1fae5;
                --gray-900: #0f172a;
                --gray-700: #334155;
                --gray-600: #475569;
                --gray-400: #94a3b8;
                --gray-200: #e2e8f0;
                --gray-100: #f1f5f9;
                --red-600: #dc2626;
                --red-50: #fef2f2;
                --white: #ffffff;
            }

            body {
                font-family: 'Inter', sans-serif;
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                color: var(--gray-900);
                background: linear-gradient(145deg, #09333f 0%, #0d4856 60%, #115e59 100%);
                background-attachment: fixed;
                position: relative;
                overflow: hidden;
            }

                body::before {
                    content: '';
                    position: fixed;
                    top: -15%;
                    left: -10%;
                    width: 550px;
                    height: 550px;
                    background: radial-gradient(circle, rgba(20,184,166,0.15) 0%, transparent 65%);
                    border-radius: 50%;
                    pointer-events: none;
                }

                body::after {
                    content: '';
                    position: fixed;
                    bottom: -15%;
                    right: -8%;
                    width: 480px;
                    height: 480px;
                    background: radial-gradient(circle, rgba(13,148,136,0.12) 0%, transparent 65%);
                    border-radius: 50%;
                    pointer-events: none;
                }

            .login-wrapper {
                display: flex;
                width: 100%;
                max-width: 1040px;
                min-height: 600px;
                border-radius: 24px;
                overflow: hidden;
                margin: 2rem;
                border: 1px solid rgba(255,255,255,0.12);
                box-shadow: 0 32px 80px rgba(4,28,35,0.4), 0 0 0 1px rgba(255,255,255,0.05);
                position: relative;
                z-index: 1;
            }

            .login-brand {
                width: 42%;
                background: rgba(255,255,255,0.04);
                backdrop-filter: blur(24px);
                -webkit-backdrop-filter: blur(24px);
                padding: 3rem 2rem;
                display: flex;
                flex-direction: column;
                justify-content: space-between;
                align-items: center;
                border-right: 1px solid rgba(255,255,255,0.08);
                text-align: center;
            }

            .brand-logo-container {
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                gap: 14px;
                width: 100%;
                min-height: 190px;
                margin-bottom: 1.5rem;
            }

            .logo-icon-img {
                width: 115px;
                height: 115px;
                object-fit: contain;
                display: block;
            }

            .logo-text-img {
                width: 225px;
                height: auto;
                object-fit: contain;
                display: block;
            }

            .brand-copy {
                width: 100%;
                max-width: 290px;
                margin: 0 auto;
                flex: 1;
                display: flex;
                flex-direction: column;
                justify-content: center;
            }

            .brand-em-line {
                width: 45px;
                height: 3px;
                background: linear-gradient(90deg, var(--teal-400), var(--em-400));
                border-radius: 2px;
                margin: 0 auto 1rem auto;
            }

            .brand-copy h2 {
                font-size: 1.6rem;
                font-weight: 600;
                color: var(--white);
                line-height: 1.35;
                margin-bottom: 0.65rem;
            }

            .brand-copy p {
                font-size: 0.85rem;
                color: rgba(255,255,255,0.65);
                line-height: 1.6;
            }

            .brand-stats {
                display: flex;
                gap: 1.5rem;
                margin-top: 1.5rem;
                justify-content: center;
                width: 100%;
            }

            .brand-stat {
                border-top: 1px solid rgba(255,255,255,0.12);
                padding-top: 0.75rem;
                flex: 1;
                max-width: 110px;
            }

                .brand-stat strong {
                    display: block;
                    font-size: 1.2rem;
                    font-weight: 700;
                    color: var(--white);
                }

                .brand-stat span {
                    display: block;
                    font-size: 0.72rem;
                    color: rgba(255,255,255,0.5);
                    margin-top: 2px;
                }

            .login-form-panel {
                flex: 1;
                padding: 4rem 4rem;
                display: flex;
                flex-direction: column;
                justify-content: center;
                background: #fafbfc;
                position: relative; /* Necesario para contener la card dinámica adentro */
            }

            .form-header {
                margin-bottom: 2.2rem;
            }

                .form-header h1 {
                    font-size: 1.65rem;
                    font-weight: 700;
                    color: var(--gray-900);
                    margin-bottom: 0.4rem;
                    text-transform: uppercase;
                    letter-spacing: 0.5px;
                }

                .form-header p {
                    font-size: 0.92rem;
                    color: var(--gray-700);
                }

            .form-group {
                margin-bottom: 1.4rem;
            }

                .form-group label {
                    display: block;
                    font-size: 0.75rem;
                    font-weight: 700;
                    color: var(--gray-700);
                    margin-bottom: 0.5rem;
                    text-transform: uppercase;
                    letter-spacing: 0.9px;
                }

                .form-group input {
                    width: 100%;
                    padding: 0.95rem 1.1rem;
                    font-family: 'Inter', sans-serif;
                    font-size: 0.95rem;
                    color: var(--gray-900);
                    background: var(--white);
                    border: 1.5px solid #cbd5e1;
                    border-radius: 12px;
                    outline: none;
                    transition: border-color 0.2s, box-shadow 0.2s;
                    line-height: 1.4;
                    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
                }

                    .form-group input:focus {
                        border-color: var(--teal-600);
                        box-shadow: 0 0 0 4px rgba(13,148,136,0.12), 0 1px 2px rgba(0, 0, 0, 0.05);
                    }

            .password-wrapper {
                position: relative;
            }

                .password-wrapper input {
                    padding-right: 4.2rem;
                }

            .password-toggle {
                position: absolute;
                right: 0.6rem;
                bottom: 0.38rem;
                width: 2.4rem;
                height: 2.4rem;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                cursor: pointer;
                border-radius: 50%;
                border: none;
                background: rgba(15,23,42,0.04);
                color: var(--gray-600);
            }

            .form-options {
                display: flex;
                justify-content: space-between;
                align-items: center;
                margin-bottom: 2rem;
                font-size: 0.88rem;
            }

            .checkbox-label {
                display: flex;
                align-items: center;
                gap: 8px;
                color: var(--gray-700);
                font-weight: 500;
                cursor: pointer;
            }

                .checkbox-label input[type="checkbox"] {
                    width: 16px;
                    height: 16px;
                    accent-color: var(--teal-600);
                }

            .btn-login {
                width: 100%;
                padding: 0.95rem;
                background: linear-gradient(135deg, var(--teal-700), var(--teal-600));
                color: var(--white);
                font-family: 'Inter', sans-serif;
                font-size: 0.95rem;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.8px;
                border: none;
                border-radius: 12px;
                cursor: pointer;
                transition: opacity 0.15s, box-shadow 0.15s;
                box-shadow: 0 4px 18px rgba(13,148,136,0.3);
            }

                .btn-login:hover {
                    opacity: 0.95;
                    box-shadow: 0 6px 24px rgba(13,148,136,0.42);
                }

            /* CARD DINÁMICA DE AYUDA (OCULTA POR DEFECTO) */
            .support-card-overlay {
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background: rgba(15, 23, 42, 0.4);
                backdrop-filter: blur(8px);
                -webkit-backdrop-filter: blur(8px);
                display: flex;
                align-items: flex-end; /* Aparece desde abajo */
                z-index: 10;
                opacity: 0;
                pointer-events: none;
                transition: opacity 0.3s ease;
            }

                .support-card-overlay.active {
                    opacity: 1;
                    pointer-events: auto;
                }

            .support-card {
                width: 100%;
                background: var(--white);
                border-radius: 24px 24px 0 0;
                padding: 2.5rem 3rem;
                box-shadow: 0 -10px 40px rgba(0,0,0,0.15);
                transform: translateY(100%);
                transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
                position: relative;
            }

            .support-card-overlay.active .support-card {
                transform: translateY(0);
            }

            .close-card-btn {
                position: absolute;
                top: 1.25rem;
                right: 1.5rem;
                background: rgba(15,23,42,0.05);
                border: none;
                width: 2rem;
                height: 2rem;
                border-radius: 50%;
                cursor: pointer;
                display: flex;
                align-items: center;
                justify-content: center;
                color: var(--gray-700);
                transition: background 0.15s;
            }

                .close-card-btn:hover {
                    background: rgba(15,23,42,0.1);
                }

            .support-title {
                font-size: 1.2rem;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                margin-bottom: 1.5rem;
                color: var(--gray-900);
                border-bottom: 2px solid var(--gray-100);
                padding-bottom: 0.5rem;
            }

            .support-option-item {
                display: flex;
                align-items: center;
                gap: 16px;
                padding: 1rem;
                background: #f8fafc;
                border: 1px solid var(--gray-200);
                border-radius: 12px;
                text-decoration: none;
                color: var(--gray-900);
                font-weight: 600;
                font-size: 0.95rem;
                margin-bottom: 0.85rem;
                transition: transform 0.15s, border-color 0.15s, background 0.15s;
            }

                .support-option-item:hover {
                    transform: translateY(-2px);
                    border-color: var(--teal-500);
                    background: var(--white);
                }

                .support-option-item span.icon {
                    font-size: 1.3rem;
                    background: var(--white);
                    width: 2.5rem;
                    height: 2.5rem;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    border-radius: 10px;
                    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
                }

            .form-footer {
                text-align: center;
                font-size: 0.88rem;
                color: var(--gray-700);
                margin-top: 2rem;
            }

                .form-footer a {
                    color: var(--teal-600);
                    text-decoration: none;
                    font-weight: 700;
                    cursor: pointer;
                }

                    .form-footer a:hover {
                        color: var(--teal-700);
                        text-decoration: underline;
                    }

            @@media (max-width: 768px) {
                .login-brand {
                    display: none;
                }

                .login-wrapper {
                    margin: 1rem;
                    border-radius: 18px;
                    max-width: 480px;
                }

                .login-form-panel {
                    padding: 3rem 2rem;
                }

                .support-card {
                    padding: 2rem 1.5rem;
                }
            }
    </style>
</head>
<body>
    <div class="login-wrapper">
        <div class="login-brand">
            <div class="brand-logo-container">
                <img src="~/img/logoVitalBand.png?v=1.5" alt="Logo VitalBand" class="logo-icon-img" />
                <img src="~/img/letrasVitalBand.png?v=1.5" alt="VitalBand" class="logo-text-img" />
            </div>

            <div class="brand-copy">
                <div class="brand-em-line"></div>
                <h2>Monitoreo cardíaco inteligente</h2>
                <p>Accede a tus métricas de salud en tiempo real, historial de incidentes y reportes personalizados.</p>
                <div class="brand-stats">
                    <div class="brand-stat">
                        <strong>24/7</strong>
                        <span>Monitoreo activo</span>
                    </div>
                    <div class="brand-stat">
                        <strong>100%</strong>
                        <span>Datos seguros</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="login-form-panel">
            @if (TempData["SuccessMessage"] != null)
            {
                <div style="background: #d1fae5; border: 1.5px solid #6ee7b7; border-radius: 10px; padding: 0.75rem 1rem; margin-bottom: 1.25rem; font-size: 0.85rem; color: #065f46; font-weight: 500; text-align: left;">
                    @TempData["SuccessMessage"]
                </div>
            }

            <div class="form-header">
                <h1>Bienvenido de vuelta</h1>
                <p>Ingresa tus credenciales para continuar</p>
            </div>

            <form asp-action="Login" asp-controller="Account" method="post">
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <label for="email">Correo electrónico</label>
                    <input type="email" id="email" name="Email" placeholder="usuario@vitalband.com" autocomplete="username" required />
                </div>

                <div class="form-group password-wrapper">
                    <label for="password">Contraseña</label>
                    <input type="password" id="password" name="Password" placeholder="••••••••" autocomplete="current-password" required />
                    <button type="button" id="togglePassword" class="password-toggle" aria-label="Mostrar contraseña">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M1 12s4.5-7 11-7 11 7 11 7-4.5 7-11 7-11-7-11-7z"></path>
                            <circle cx="12" cy="12" r="3"></circle>
                        </svg>
                    </button>
                </div>

                <div class="form-options">
                    <label class="checkbox-label">
                        <input type="checkbox" name="RememberMe" value="true" />
                        Mantener sesión iniciada
                    </label>
                </div>

                <button type="submit" class="btn-login">Iniciar Sesión</button>
            </form>

            <p class="form-footer">¿Necesitas ayuda? <a id="openSupportLink">Más información aquí</a></p>

            <!-- CARD DINÁMICA DE ACCESOS Y SOPORTE -->
            <div class="support-card-overlay" id="supportOverlay">
                <div class="support-card">
                    <button type="button" class="close-card-btn" id="closeSupportBtn" aria-label="Cerrar">✕</button>
                    <h2 class="support-title">Centro de ayuda y accesos</h2>

                    <a asp-action="ForgotPassword" asp-controller="Account" class="support-option-item">
                        <span class="icon">🔑</span>
                        <div>¿Olvidaste tu contraseña? Recuperarla aquí</div>
                    </a>

                    <a asp-action="RegistroMedico" asp-controller="Account" class="support-option-item">
                        <span class="icon">🩺</span>
                        <div>¿Eres especialista médico? Regístrate aquí</div>
                    </a>

                    <a href="#" class="support-option-item" style="margin-bottom: 0;">
                        <span class="icon">🛠️</span>
                        <div>Contactar con soporte técnico directo</div>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <script>
            document.addEventListener('DOMContentLoaded', function() {
                // Password Toggle
                var toggle = document.getElementById('togglePassword');
                var password = document.getElementById('password');
                if (toggle && password) {
                    toggle.addEventListener('click', function() {
                        var type = password.getAttribute('type') === 'password' ? 'text' : 'password';
                        password.setAttribute('type', type);
                        toggle.innerHTML = type === 'password'
                            ? '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4.5-7 11-7 11 7 11 7-4.5 7-11 7-11-7-11-7z"></path><circle cx="12" cy="12" r="3"></circle></svg>'
                            : '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.94 10.94 0 0 1 12 19c-6.5 0-11-7-11-7a21.88 21.88 0 0 1 5.06-6.94"></path><path d="M1 1l22 22"></path></svg>';
                    });
                }

                // Lógica para abrir y cerrar la Card Dinámica
                var overlay = document.getElementById('supportOverlay');
                var openBtn = document.getElementById('openSupportLink');
                var closeBtn = document.getElementById('closeSupportBtn');

                if(openBtn && overlay && closeBtn) {
                    openBtn.addEventListener('click', function() {
                        overlay.classList.add('active');
                    });

                    closeBtn.addEventListener('click', function() {
                        overlay.classList.remove('active');
                    });

                    // Cierra al hacer clic en el fondo borroso externo
                    overlay.addEventListener('click', function(e) {
                        if (e.target === overlay) {
                            overlay.classList.remove('active');
                        }
                    });
                }
            });
    </script>
</body>
</html>