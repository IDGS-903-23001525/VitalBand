@{
    ViewData["Title"] = "Registro Clinico de Onboarding - VitalBand";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --teal-700: #0a6775;
            --teal-600: #0891b2;
            --teal-500: #06b6d4;
            --teal-400: #22d3ee;
            --teal-100: #cffafe;
            --em-600: #059669;
            --em-500: #10b981;
            --em-400: #34d399;
            --em-100: #d1fae5;
            --gray-900: #0f172a;
            --gray-700: #334155;
            --gray-600: #475569;
            --gray-400: #94a3b8;
            --gray-200: #e2e8f0;
            --gray-100: #f1f5f9;
            --red-600: #dc2626;
            --red-50: #fef2f2;
            --white: #ffffff;
        }

        body {
            font-family: 'Inter', sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--gray-900);
            background: linear-gradient(145deg, #0d3d40 0%, #065f46 40%, #0891b2 75%, #22d3ee 100%);
            background-attachment: fixed;
            position: relative;
            overflow-x: hidden;
            padding: 2rem 0;
        }

        body::before {
            content: '';
            position: fixed;
            top: -15%;
            left: -10%;
            width: 550px;
            height: 550px;
            background: radial-gradient(circle, rgba(52,211,153,0.2) 0%, transparent 65%);
            border-radius: 50%;
            pointer-events: none;
        }

        body::after {
            content: '';
            position: fixed;
            bottom: -15%;
            right: -8%;
            width: 480px;
            height: 480px;
            background: radial-gradient(circle, rgba(34,211,238,0.18) 0%, transparent 65%);
            border-radius: 50%;
            pointer-events: none;
        }

        .login-wrapper {
            display: flex;
            width: 100%;
            max-width: 980px;
            height: auto;
            min-height: 750px;
            border-radius: 24px;
            overflow: hidden;
            margin: auto 2rem;
            border: 1px solid rgba(255,255,255,0.18);
            box-shadow: 0 32px 80px rgba(0,0,0,0.28), 0 0 0 1px rgba(255,255,255,0.08);
            position: relative;
            z-index: 1;
        }

        .login-brand {
            width: 38%;
            background: rgba(255,255,255,0.07);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            padding: 3rem;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            border-right: 1px solid rgba(255,255,255,0.12);
        }

        .brand-logo {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .brand-logo-icon {
            width: 38px;
            height: 38px;
            background: rgba(255,255,255,0.12);
            border-radius: 11px;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 1px solid rgba(255,255,255,0.2);
        }

        .brand-logo-icon svg {
            width: 20px;
            height: 20px;
        }

        .brand-logo-text {
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--white);
            letter-spacing: -0.3px;
        }

        .brand-copy {
            margin-top: auto;
        }

        .brand-copy h2 {
            font-size: 1.45rem;
            font-weight: 600;
            color: var(--white);
            line-height: 1.4;
            margin-bottom: 0.75rem;
        }

        .brand-copy p {
            font-size: 0.85rem;
            color: rgba(255,255,255,0.62);
            line-height: 1.7;
        }

        .brand-em-line {
            width: 40px;
            height: 3px;
            background: linear-gradient(90deg, var(--em-400), var(--teal-400));
            border-radius: 2px;
            margin-bottom: 1.25rem;
        }

        .login-form-panel {
            flex: 1;
            padding: 2.5rem;
            display: flex;
            flex-direction: column;
            background: rgba(255,255,255,0.94);
            backdrop-filter: blur(24px) saturate(160%);
            -webkit-backdrop-filter: blur(24px) saturate(160%);
            overflow-y: auto;
            max-height: 90vh;
        }

        .form-header {
            margin-bottom: 1.5rem;
        }

        .form-header h1 {
            font-size: 1.45rem;
            font-weight: 700;
            color: var(--gray-900);
            margin-bottom: 0.35rem;
        }

        .form-header p {
            font-size: 0.85rem;
            color: var(--gray-600);
        }

        .section-title {
            font-size: 0.85rem;
            font-weight: 700;
            color: var(--teal-700);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin: 1.5rem 0 0.75rem 0;
            border-bottom: 1px solid var(--gray-200);
            padding-bottom: 0.25rem;
        }

        .section-title.first {
            margin-top: 0;
        }

        .form-row {
            display: flex;
            gap: 1rem;
            margin-bottom: 1rem;
        }

        .form-group {
            flex: 1;
            margin-bottom: 1rem;
        }

        .form-group.row-item {
            margin-bottom: 0;
        }

        .form-group label {
            display: block;
            font-size: 0.72rem;
            font-weight: 600;
            color: var(--gray-600);
            margin-bottom: 0.4rem;
            text-transform: uppercase;
            letter-spacing: 0.7px;
        }

        .form-group input, .form-group textarea, .form-group select {
            width: 100%;
            padding: 0.65rem 1rem;
            font-family: 'Inter', sans-serif;
            font-size: 0.9rem;
            color: var(--gray-900);
            background: rgba(248,250,252,0.9);
            border: 1.5px solid var(--gray-200);
            border-radius: 10px;
            outline: none;
            transition: border-color 0.15s, box-shadow 0.15s;
        }

        .form-group textarea {
            resize: none;
            height: 70px;
        }

        .form-group input:focus, .form-group textarea:focus, .form-group select:focus {
            border-color: var(--teal-500);
            box-shadow: 0 0 0 3px rgba(6,182,212,0.14);
            background: var(--white);
        }

        .gender-group {
            display: flex;
            gap: 1rem;
            margin-top: 0.25rem;
        }

        .gender-option {
            flex: 1;
            position: relative;
        }

        .gender-option input[type="radio"] {
            position: absolute;
            opacity: 0;
            width: 0;
            height: 0;
        }

        .gender-label {
            display: block;
            text-align: center;
            padding: 0.55rem;
            background: rgba(248,250,252,0.9);
            border: 1.5px solid var(--gray-200);
            border-radius: 10px;
            cursor: pointer;
            font-size: 0.85rem;
            font-weight: 500;
            transition: all 0.2s;
        }

        .gender-option input[type="radio"]:checked + .gender-label {
            background: var(--teal-100);
            border-color: var(--teal-500);
            color: var(--teal-700);
            font-weight: 600;
        }

        .patologias-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 0.5rem;
            background: rgba(248,250,252,0.9);
            border: 1.5px solid var(--gray-200);
            border-radius: 10px;
            padding: 0.75rem;
        }

        .patologia-item {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.85rem;
            color: var(--gray-700);
            cursor: pointer;
        }

        .patologia-item input {
            width: auto;
            accent-color: var(--teal-600);
            cursor: pointer;
        }

        .btn-register {
            width: 100%;
            padding: 0.78rem;
            background: linear-gradient(135deg, var(--teal-700), var(--teal-500));
            color: var(--white);
            font-family: 'Inter', sans-serif;
            font-size: 0.9rem;
            font-weight: 600;
            border: none;
            border-radius: 10px;
            cursor: pointer;
            transition: opacity 0.15s, transform 0.1s, box-shadow 0.15s;
            box-shadow: 0 4px 16px rgba(6,182,212,0.35);
            margin-top: 1.5rem;
        }

        .btn-register:hover {
            opacity: 0.91;
            box-shadow: 0 6px 22px rgba(6,182,212,0.45);
        }

        .btn-register:active {
            transform: scale(0.99);
        }

        .validation-summary-custom {
            background: var(--red-50);
            border: 1.5px solid #fca5a5;
            border-radius: 10px;
            padding: 0.75rem 1rem;
            margin-bottom: 1.25rem;
            font-size: 0.85rem;
            color: var(--red-600);
        }

        .divider {
            border: none;
            border-top: 1px solid var(--gray-200);
            margin: 1.5rem 0 1rem 0;
        }

        .form-footer {
            text-align: center;
            font-size: 0.8rem;
            color: var(--gray-400);
        }

        .form-footer a {
            color: var(--teal-600);
            text-decoration: none;
            font-weight: 500;
        }
    </style>
</head>
<body>
    <div class="login-wrapper">
        <div class="login-brand">
            <div class="brand-logo">
                <div class="brand-logo-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 12 L7 7 L11 15 L15 5 L19 12" />
                    </svg>
                </div>
                <span class="brand-logo-text">VitalBand</span>
            </div>

            <div class="brand-copy">
                <div class="brand-em-line"></div>
                <h2>Tu Ficha de Onboarding</h2>
                <p>Configura tu cuenta base, anade tus patologias para alimentar los algoritmos preventivos de nuestra IA y define tu red de seguridad inmediata.</p>
            </div>
        </div>

        <div class="login-form-panel">
            <div class="form-header">
                <h1>Unete a VitalBand</h1>
                <p>Completa tu registro clinico esencial antes de iniciar</p>
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="validation-summary-custom">
                    @ViewBag.Error
                </div>
            }

            <form asp-action="RegistroPaciente" asp-controller="Account" method="post">
                @Html.AntiForgeryToken()

                <div class="section-title first">1. Informacion Personal y Cuenta</div>

                <div class="form-group">
                    <label for="Nombre">Nombre Completo</label>
                    <input type="text" id="Nombre" name="Nombre" placeholder="Juan Perez Lopez" required />
                </div>

                <div class="form-row">
                    <div class="form-group row-item">
                        <label for="Email">Correo Electronico</label>
                        <input type="email" id="Email" name="Email" placeholder="paciente@vitalband.com" required />
                    </div>
                    <div class="form-group row-item">
                        <label for="Password">Contrasena</label>
                        <input type="password" id="Password" name="Password" placeholder="********" required />
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group row-item">
                        <label for="FechaNacimiento">Fecha de Nacimiento</label>
                        <input type="date" id="FechaNacimiento" name="FechaNacimiento" required />
                    </div>
                    <div class="form-group row-item">
                        <label>Genero Biologico</label>
                        <div class="gender-group">
                            <div class="gender-option">
                                <input type="radio" id="genM" name="Sexo" value="Masculino" checked />
                                <label for="genM" class="gender-label">M</label>
                            </div>
                            <div class="gender-option">
                                <input type="radio" id="genF" name="Sexo" value="Femenino" />
                                <label for="genF" class="gender-label">F</label>
                            </div>
                            <div class="gender-option">
                                <input type="radio" id="genO" name="Sexo" value="Otro" />
                                <label for="genO" class="gender-label">Otro</label>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group row-item">
                        <label for="TipoSangre">Tipo de Sangre</label>
                        <select id="TipoSangre" name="TipoSangre">
                            <option value="">Seleccionar...</option>
                            <option value="A+">A+</option>
                            <option value="A-">A-</option>
                            <option value="B+">B+</option>
                            <option value="B-">B-</option>
                            <option value="AB+">AB+</option>
                            <option value="AB-">AB-</option>
                            <option value="O+">O+</option>
                            <option value="O-">O-</option>
                        </select>
                    </div>
                    <div class="form-group row-item">
                        <label for="Peso">Peso Actual (kg)</label>
                        <input type="number" step="0.1" id="Peso" name="Peso" placeholder="70.5" required />
                    </div>
                    <div class="form-group row-item">
                        <label for="Altura">Altura (m)</label>
                        <input type="number" step="0.01" id="Altura" name="Altura" placeholder="1.75" required />
                    </div>
                </div>

                <div class="section-title">2. Historial de Patologias (Alimentacion de IA)</div>
                <div class="form-group">
                    <label style="margin-bottom: 0.5rem; color: var(--gray-400); text-transform: none; letter-spacing: normal;">
                        Selecciona las condiciones previas diagnosticadas:
                    </label>
                    <div class="patologias-grid">
                        <label class="patologia-item"><input type="checkbox" name="PatologiasIds" value="1" /> Hipertension Arterial</label>
                        <label class="patologia-item"><input type="checkbox" name="PatologiasIds" value="2" /> Arritmia Sinusal</label>
                        <label class="patologia-item"><input type="checkbox" name="PatologiasIds" value="3" /> Diabetes Tipo 2</label>
                        <label class="patologia-item"><input type="checkbox" name="PatologiasIds" value="4" /> Asma Cronica</label>
                    </div>
                </div>

                <div class="form-group">
                    <label for="HistorialMedico">Breve Historial Medico Adicional</label>
                    <textarea id="HistorialMedico" name="HistorialMedico" placeholder="Alergias, medicamentos tomados actualmente, etc..."></textarea>
                </div>

                <div class="section-title">3. Contacto de Emergencia Prioritario</div>
                <div class="form-group">
                    <label for="NombreContacto">Nombre del Contacto</label>
                    <input type="text" id="NombreContacto" name="NombreContacto" placeholder="Nombre completo del familiar" required />
                </div>

                <div class="form-row">
                    <div class="form-group row-item">
                        <label for="ParentescoContacto">Parentesco</label>
                        <input type="text" id="ParentescoContacto" name="ParentescoContacto" placeholder="Ej. Esposa, Madre, Padre" required />
                    </div>
                    <div class="form-group row-item">
                        <label for="TelefonoContacto">Telefono Celular</label>
                        <input type="tel" id="TelefonoContacto" name="TelefonoContacto" placeholder="+52 477 123 4567" required />
                    </div>
                </div>

                <button type="submit" class="btn-register">Finalizar Onboarding Clinico</button>
            </form>

            <div style="text-align: center; margin-top: 1.25rem; border-top: 1px solid rgba(6,182,212,0.15); padding-top: 1.25rem;">
                <p style="font-size: 0.85rem; color: #475569; margin-bottom: 0.5rem;">Ya tienes una cuenta registrada?</p>
                <a asp-action="Login" asp-controller="Account" style="color: var(--teal-600); font-weight: 700; font-size: 0.9rem; text-decoration: none;">
                    Inicia sesion aqui
                </a>
            </div>

            <hr class="divider" />
            <p class="form-footer">Necesitas ayuda? <a href="#">Contactar soporte tecnico</a></p>
        </div>
    </div>
</body>
</html>
